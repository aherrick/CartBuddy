<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:models="clr-namespace:CartBuddy.Shared.Models;assembly=CartBuddy.Shared"
             xmlns:vm="clr-namespace:CartBuddy.ViewModels"
             xmlns:converters="clr-namespace:CartBuddy.Converters"
             xmlns:sfListView="clr-namespace:Syncfusion.Maui.ListView;assembly=Syncfusion.Maui.ListView"
             xmlns:bottomsheet="http://pluginmauibottomsheet.com"
             x:Class="CartBuddy.LogsPage"
             x:Name="ThisPage"
             Title="API Logs"
             BackgroundColor="{AppThemeBinding Light={StaticResource Gray100}, Dark={StaticResource Gray950}}">

    <ContentPage.Resources>
        <converters:DirectionColorConverter x:Key="DirectionColorConverter" />
        <converters:DirectionGlyphConverter x:Key="DirectionGlyphConverter" />
    </ContentPage.Resources>

    <Grid RowDefinitions="Auto,*">

        <!-- Header -->
        <VerticalStackLayout Padding="16,14,16,14" Spacing="14">
            <Grid ColumnDefinitions="*,Auto">
                <VerticalStackLayout Spacing="2" VerticalOptions="Center">
                    <Label Text="API Logs" FontSize="22" FontAttributes="Bold" />
                    <Label Text="{Binding Logs.Count, StringFormat='{0} entries'}"
                           FontSize="12"
                           TextColor="{StaticResource Gray400}" />
                </VerticalStackLayout>
                <Button Grid.Column="1"
                        Text="Refresh"
                        Command="{Binding LoadLogsCommand}"
                        Padding="12,8"
                        FontSize="12"
                        CornerRadius="6"
                        VerticalOptions="Center" />
            </Grid>

            <BoxView HeightRequest="1"
                     BackgroundColor="{AppThemeBinding Light={StaticResource Gray200}, Dark={StaticResource Gray600}}" />
        </VerticalStackLayout>

        <!-- Log list -->
        <sfListView:SfListView Grid.Row="1"
                               ItemsSource="{Binding Logs}"
                               SelectionMode="None"
                               AutoFitMode="Height"
                               ItemTapped="OnEntryTapped">
            <sfListView:SfListView.EmptyView>
                <Label Text="No logs yet — make some API calls and refresh"
                       FontSize="14"
                       HorizontalOptions="Center"
                       VerticalOptions="Center"
                       TextColor="{StaticResource Gray400}"
                       Margin="32" />
            </sfListView:SfListView.EmptyView>
            <sfListView:SfListView.ItemTemplate>
                <DataTemplate x:DataType="models:ApiLogEntry">
                    <Grid Padding="16,12,16,12"
                          ColumnDefinitions="Auto,*,Auto"
                          ColumnSpacing="12">

                        <!-- Direction badge -->
                        <Border WidthRequest="28"
                                HeightRequest="28"
                                StrokeThickness="0"
                                VerticalOptions="Center"
                                BackgroundColor="{Binding Direction, Converter={StaticResource DirectionColorConverter}}">
                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="6" />
                            </Border.StrokeShape>
                            <Label Text="{Binding Direction, Converter={StaticResource DirectionGlyphConverter}}"
                                   FontFamily="FaSolid"
                                   FontSize="11"
                                   TextColor="White"
                                   HorizontalOptions="Center"
                                   VerticalOptions="Center" />
                        </Border>

                        <!-- Method + timestamp -->
                        <VerticalStackLayout Grid.Column="1" Spacing="2" VerticalOptions="Center">
                            <Label Text="{Binding MethodName}"
                                   FontSize="14"
                                   FontAttributes="Bold"
                                   LineBreakMode="TailTruncation" />
                            <Label Text="{Binding Timestamp, StringFormat='{0:MM/dd HH:mm:ss}'}"
                                   FontSize="11"
                                   TextColor="{StaticResource Gray400}" />
                        </VerticalStackLayout>

                        <!-- Chevron -->
                        <Label Grid.Column="2"
                               Text="&#xF054;"
                               FontFamily="FaSolid"
                               FontSize="12"
                               TextColor="{StaticResource Gray400}"
                               VerticalOptions="Center" />
                    </Grid>
                </DataTemplate>
            </sfListView:SfListView.ItemTemplate>
        </sfListView:SfListView>

        <!-- Detail bottom sheet -->
        <bottomsheet:BottomSheet Grid.RowSpan="2"
                                 IsOpen="{Binding IsDetailOpen}"
                                 IsVisible="{Binding IsDetailOpen}"
                                 IsModal="True"
                                 IsCancelable="True"
                                 IsDraggable="True"
                                 HasHandle="True"
                                 ShowHeader="False"
                                 States="Medium,Large"
                                 CurrentState="Medium">
            <bottomsheet:BottomSheetContent>
                <bottomsheet:BottomSheetContent.ContentTemplate>
                    <DataTemplate>
                        <VerticalStackLayout Padding="16,12,16,16" Spacing="12">
                            <VerticalStackLayout Spacing="2">
                                <Label Text="{Binding SelectedEntry.MethodName}"
                                       FontSize="18"
                                       FontAttributes="Bold" />
                                <Label Text="{Binding SelectedEntry.Direction}"
                                       FontSize="12"
                                       TextColor="{StaticResource Gray400}" />
                                <Label Text="{Binding SelectedEntry.Timestamp, StringFormat='{0:yyyy-MM-dd HH:mm:ss} UTC'}"
                                       FontSize="12"
                                       TextColor="{StaticResource Gray400}" />
                            </VerticalStackLayout>

                            <ScrollView HeightRequest="380">
                                <Label Text="{Binding SelectedEntry.Payload}"
                                       FontSize="11"
                                       LineBreakMode="CharacterWrap" />
                            </ScrollView>
                        </VerticalStackLayout>
                    </DataTemplate>
                </bottomsheet:BottomSheetContent.ContentTemplate>
            </bottomsheet:BottomSheetContent>
        </bottomsheet:BottomSheet>
    </Grid>

</ContentPage>