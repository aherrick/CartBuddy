<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:models="clr-namespace:CartBuddy.Shared.Models;assembly=CartBuddy.Shared"
             xmlns:converters="clr-namespace:CartBuddy.Converters"
             xmlns:sfListView="clr-namespace:Syncfusion.Maui.ListView;assembly=Syncfusion.Maui.ListView"
             xmlns:data="clr-namespace:Syncfusion.Maui.DataSource;assembly=Syncfusion.Maui.DataSource"
             xmlns:toolkit="http://schemas.microsoft.com/dotnet/2022/maui/toolkit"
             x:Class="CartBuddy.LogsPage"
             x:Name="ThisPage"
             Title="API Logs"
             BackgroundColor="{AppThemeBinding Light={StaticResource Gray100}, Dark={StaticResource Gray950}}">

    <ContentPage.Behaviors>
        <toolkit:StatusBarBehavior StatusBarColor="{AppThemeBinding Light={StaticResource Gray100}, Dark={StaticResource Gray950}}" StatusBarStyle="{AppThemeBinding Light=DarkContent, Dark=LightContent}" />
    </ContentPage.Behaviors>

    <ContentPage.Resources>
        <converters:ApiLogGroupHeaderConverter x:Key="ApiLogGroupHeaderConverter" />
    </ContentPage.Resources>

    <Grid RowDefinitions="*">

        <RefreshView Grid.Row="0"
                     Refreshing="OnRefreshLogs">
            <!-- Log list -->
            <sfListView:SfListView ItemsSource="{Binding Logs}"
                                   SelectionMode="None"
                                   AutoFitMode="Height"
                                   GroupHeaderSize="58"
                                   AllowGroupExpandCollapse="False"
                                   IsStickyGroupHeader="True"
                                   ItemTapped="OnItemTapped">
            <sfListView:SfListView.DataSource>
                <data:DataSource AutoExpandGroups="True">
                    <data:DataSource.GroupDescriptors>
                        <data:GroupDescriptor PropertyName="TransactionId" />
                    </data:DataSource.GroupDescriptors>
                </data:DataSource>
            </sfListView:SfListView.DataSource>
            <sfListView:SfListView.EmptyView>
                <Label Text="No logs yet - pull to refresh after making API calls"
                       FontSize="14"
                       HorizontalOptions="Center"
                       VerticalOptions="Center"
                       TextColor="{StaticResource Gray400}"
                       Margin="32" />
            </sfListView:SfListView.EmptyView>
            <sfListView:SfListView.GroupHeaderTemplate>
                <DataTemplate>
                    <Grid BackgroundColor="{AppThemeBinding Light={StaticResource Gray100}, Dark={StaticResource Gray950}}"
                          Padding="16,10,16,10"
                          ColumnDefinitions="*,Auto"
                          ColumnSpacing="8">
                        <VerticalStackLayout Spacing="2" VerticalOptions="Center">
                            <Label Text="{Binding ., Converter={StaticResource ApiLogGroupHeaderConverter}, ConverterParameter=MethodName}"
                                   FontSize="17"
                                   FontAttributes="Bold" />
                            <Label Text="{Binding ., Converter={StaticResource ApiLogGroupHeaderConverter}, ConverterParameter=DirectionSummary}"
                                   FontSize="11"
                                   LineBreakMode="TailTruncation"
                                   TextColor="{StaticResource Gray400}" />
                        </VerticalStackLayout>
                        <VerticalStackLayout Grid.Column="1" Spacing="2" HorizontalOptions="End" VerticalOptions="Center">
                            <Label Text="{Binding ., Converter={StaticResource ApiLogGroupHeaderConverter}, ConverterParameter=EntryCountLabel}"
                                   FontSize="13"
                                   HorizontalTextAlignment="End"
                                   TextColor="{StaticResource Gray400}" />
                            <Label Text="{Binding ., Converter={StaticResource ApiLogGroupHeaderConverter}, ConverterParameter=Timestamp}"
                                   FontSize="11"
                                   HorizontalTextAlignment="End"
                                   TextColor="{StaticResource Gray400}" />
                        </VerticalStackLayout>
                    </Grid>
                </DataTemplate>
            </sfListView:SfListView.GroupHeaderTemplate>
            <sfListView:SfListView.ItemTemplate>
                <DataTemplate x:DataType="models:ApiLogEntry">
                    <Grid Padding="16,12,16,12"
                          ColumnDefinitions="Auto,*,Auto"
                          ColumnSpacing="12">

                        <!-- Direction badge -->
                        <Border WidthRequest="28"
                                HeightRequest="28"
                                StrokeThickness="0"
                                VerticalOptions="Center"
                                BackgroundColor="{Binding Direction, Converter={StaticResource DirectionColorConverter}}">
                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="6" />
                            </Border.StrokeShape>
                            <Label Text="{Binding Direction, Converter={StaticResource DirectionGlyphConverter}}"
                                   FontFamily="FaSolid"
                                   FontSize="11"
                                   TextColor="White"
                                   HorizontalOptions="Center"
                                   VerticalOptions="Center" />
                        </Border>

                        <!-- Method + timestamp -->
                        <VerticalStackLayout Grid.Column="1" Spacing="2" VerticalOptions="Center">
                            <Label Text="{Binding MethodName}"
                                   FontSize="14"
                                   FontAttributes="Bold"
                                   LineBreakMode="TailTruncation" />
                            <HorizontalStackLayout Spacing="6">
                                <Label Text="{Binding DirectionLabel}"
                                       FontSize="11"
                                       TextColor="{StaticResource Gray400}" />
                            </HorizontalStackLayout>
                            <Label Text="{Binding PayloadPreview}"
                                   FontSize="11"
                                   LineBreakMode="TailTruncation"
                                   MaxLines="1"
                                   TextColor="{StaticResource Gray400}" />
                            <Label Text="{Binding Timestamp, StringFormat='{0:MM/dd HH:mm:ss}'}"
                                   FontSize="11"
                                   TextColor="{StaticResource Gray400}" />
                        </VerticalStackLayout>

                        <!-- Chevron -->
                        <Label Grid.Column="2"
                               Text="&#xF054;"
                               FontFamily="FaSolid"
                               FontSize="13"
                               TextColor="{StaticResource Gray400}"
                               VerticalOptions="Center" />
                    </Grid>
                </DataTemplate>
            </sfListView:SfListView.ItemTemplate>
            </sfListView:SfListView>
        </RefreshView>

    </Grid>

</ContentPage>
