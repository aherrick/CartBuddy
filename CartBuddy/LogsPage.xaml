<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:models="clr-namespace:CartBuddy.Shared.Models;assembly=CartBuddy.Shared"
             xmlns:vm="clr-namespace:CartBuddy.ViewModels"
             xmlns:localModels="clr-namespace:CartBuddy.Models"
             xmlns:converters="clr-namespace:CartBuddy.Converters"
             xmlns:bottomsheet="http://pluginmauibottomsheet.com"
             x:Class="CartBuddy.LogsPage"
             x:Name="ThisPage"
             Title="API Logs"
             BackgroundColor="{AppThemeBinding Light={StaticResource Gray100}, Dark={StaticResource Gray950}}">

    <ContentPage.Resources>
        <converters:DirectionColorConverter x:Key="DirectionColorConverter" />
        <converters:DirectionGlyphConverter x:Key="DirectionGlyphConverter" />
    </ContentPage.Resources>

    <Grid RowDefinitions="Auto,*">

        <!-- Header -->
        <VerticalStackLayout Padding="16,14,16,14" Spacing="14">
            <Grid ColumnDefinitions="*,Auto">
                <VerticalStackLayout Spacing="2" VerticalOptions="Center">
                    <Label Text="API Logs" FontSize="22" FontAttributes="Bold" />
                          <Label Text="{Binding TransactionGroups.Count, StringFormat='{0} transactions'}"
                           FontSize="12"
                           TextColor="{StaticResource Gray400}" />
                </VerticalStackLayout>
                <Button Grid.Column="1"
                        Text="Refresh"
                        Command="{Binding LoadLogsCommand}"
                        Padding="12,8"
                        FontSize="12"
                        CornerRadius="6"
                        VerticalOptions="Center" />
            </Grid>

            <BoxView HeightRequest="1"
                     BackgroundColor="{AppThemeBinding Light={StaticResource Gray200}, Dark={StaticResource Gray600}}" />
        </VerticalStackLayout>

        <!-- Log list -->
        <CollectionView Grid.Row="1"
                        IsGrouped="True"
                        ItemsSource="{Binding TransactionGroups}"
                        SelectionMode="None">
            <CollectionView.EmptyView>
                <Label Text="No logs yet — make some API calls and refresh"
                       FontSize="14"
                       HorizontalOptions="Center"
                       VerticalOptions="Center"
                       TextColor="{StaticResource Gray400}"
                       Margin="32" />
            </CollectionView.EmptyView>
            <CollectionView.GroupHeaderTemplate>
                <DataTemplate x:DataType="localModels:LogTransactionGroup">
                    <VerticalStackLayout Padding="16,12,16,4" Spacing="4">
                        <Label Text="{Binding MethodName}"
                               FontSize="15"
                               FontAttributes="Bold" />
                        <HorizontalStackLayout Spacing="6">
                            <Label Text="{Binding EntryCountLabel}"
                                   FontSize="11"
                                   TextColor="{StaticResource Gray400}" />
                            <Label Text="•"
                                   FontSize="11"
                                   TextColor="{StaticResource Gray400}" />
                            <Label Text="{Binding Timestamp, StringFormat='{0:MM/dd HH:mm:ss}'}"
                                   FontSize="11"
                                   TextColor="{StaticResource Gray400}" />
                        </HorizontalStackLayout>
                    </VerticalStackLayout>
                </DataTemplate>
            </CollectionView.GroupHeaderTemplate>
            <CollectionView.ItemTemplate>
                <DataTemplate x:DataType="models:ApiLogEntry">
                    <Grid Padding="16,12,16,12"
                          ColumnDefinitions="Auto,*,Auto"
                          ColumnSpacing="12">

                        <Grid.GestureRecognizers>
                            <TapGestureRecognizer Command="{Binding Source={x:Reference ThisPage}, Path=BindingContext.SelectEntryCommand}"
                                                  CommandParameter="{Binding .}" />
                        </Grid.GestureRecognizers>

                        <!-- Direction badge -->
                        <Border WidthRequest="28"
                                HeightRequest="28"
                                StrokeThickness="0"
                                VerticalOptions="Center"
                                BackgroundColor="{Binding Direction, Converter={StaticResource DirectionColorConverter}}">
                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="6" />
                            </Border.StrokeShape>
                            <Label Text="{Binding Direction, Converter={StaticResource DirectionGlyphConverter}}"
                                   FontFamily="FaSolid"
                                   FontSize="11"
                                   TextColor="White"
                                   HorizontalOptions="Center"
                                   VerticalOptions="Center" />
                        </Border>

                        <!-- Method + timestamp -->
                        <VerticalStackLayout Grid.Column="1" Spacing="2" VerticalOptions="Center">
                            <Label Text="{Binding MethodName}"
                                   FontSize="14"
                                   FontAttributes="Bold"
                                   LineBreakMode="TailTruncation" />
                            <HorizontalStackLayout Spacing="6">
                                <Label Text="{Binding DirectionLabel}"
                                    FontSize="11"
                                    TextColor="{StaticResource Gray400}" />
                            </HorizontalStackLayout>
                            <Label Text="{Binding PayloadPreview}"
                                FontSize="11"
                                LineBreakMode="TailTruncation"
                                MaxLines="1"
                                TextColor="{StaticResource Gray400}" />
                            <Label Text="{Binding Timestamp, StringFormat='{0:MM/dd HH:mm:ss}'}"
                                   FontSize="11"
                                   TextColor="{StaticResource Gray400}" />
                        </VerticalStackLayout>

                        <!-- Chevron -->
                        <Label Grid.Column="2"
                               Text="&#xF054;"
                               FontFamily="FaSolid"
                               FontSize="12"
                               TextColor="{StaticResource Gray400}"
                               VerticalOptions="Center" />
                    </Grid>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>

        <!-- Detail bottom sheet -->
        <bottomsheet:BottomSheet Grid.RowSpan="2"
                                 IsOpen="{Binding IsDetailOpen}"
                                 IsVisible="{Binding IsDetailOpen}"
                                 IsModal="True"
                                 IsCancelable="True"
                                 IsDraggable="True"
                                 HasHandle="True"
                                 ShowHeader="False"
                                 States="Medium,Large"
                                 CurrentState="Medium">
            <bottomsheet:BottomSheetContent>
                <bottomsheet:BottomSheetContent.ContentTemplate>
                    <DataTemplate>
                        <VerticalStackLayout Padding="16,12,16,16" Spacing="12">
                            <VerticalStackLayout Spacing="2">
                                <Label Text="{Binding SelectedTransaction.MethodName}"
                                       FontSize="18"
                                       FontAttributes="Bold" />
                                <HorizontalStackLayout Spacing="8">
                                    <Label Text="{Binding SelectedTransaction.EntryCountLabel}"
                                           FontSize="12"
                                           TextColor="{StaticResource Gray400}" />
                                    <Label Text="•"
                                           FontSize="12"
                                           TextColor="{StaticResource Gray400}" />
                                    <Label Text="{Binding SelectedTransaction.Timestamp, StringFormat='{0:yyyy-MM-dd HH:mm:ss} UTC'}"
                                           FontSize="12"
                                           TextColor="{StaticResource Gray400}" />
                                </HorizontalStackLayout>
                            </VerticalStackLayout>

                            <Button Text="Copy Transaction"
                                    Command="{Binding CopyTransactionCommand}"
                                    HorizontalOptions="Start"
                                    Padding="12,8"
                                    FontSize="12"
                                    CornerRadius="8" />

                            <ScrollView HeightRequest="380">
                                <VerticalStackLayout BindableLayout.ItemsSource="{Binding SelectedTransaction}"
                                                     Spacing="12">
                                    <BindableLayout.ItemTemplate>
                                        <DataTemplate x:DataType="models:ApiLogEntry">
                                            <Border StrokeThickness="0"
                                                    Padding="12"
                                                    BackgroundColor="{AppThemeBinding Light={StaticResource Gray100}, Dark={StaticResource Gray800}}">
                                                <Border.StrokeShape>
                                                    <RoundRectangle CornerRadius="12" />
                                                </Border.StrokeShape>
                                                <VerticalStackLayout Spacing="8">
                                                    <HorizontalStackLayout Spacing="8">
                                                        <Border Padding="8,4"
                                                                StrokeThickness="0"
                                                                BackgroundColor="{Binding Direction, Converter={StaticResource DirectionColorConverter}}">
                                                            <Border.StrokeShape>
                                                                <RoundRectangle CornerRadius="999" />
                                                            </Border.StrokeShape>
                                                            <Label Text="{Binding DirectionLabel}"
                                                                   FontSize="11"
                                                                   TextColor="White" />
                                                        </Border>
                                                        <Label Text="{Binding Timestamp, StringFormat='{0:HH:mm:ss} UTC'}"
                                                               FontSize="11"
                                                               TextColor="{StaticResource Gray400}"
                                                               VerticalOptions="Center" />
                                                    </HorizontalStackLayout>
                                                    <Label Text="{Binding Payload}"
                                                           FontSize="11"
                                                           LineBreakMode="CharacterWrap" />
                                                </VerticalStackLayout>
                                            </Border>
                                        </DataTemplate>
                                    </BindableLayout.ItemTemplate>
                                </VerticalStackLayout>
                            </ScrollView>
                        </VerticalStackLayout>
                    </DataTemplate>
                </bottomsheet:BottomSheetContent.ContentTemplate>
            </bottomsheet:BottomSheetContent>
        </bottomsheet:BottomSheet>
    </Grid>

</ContentPage>