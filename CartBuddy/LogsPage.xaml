<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:models="clr-namespace:CartBuddy.Shared.Models;assembly=CartBuddy.Shared"
             xmlns:vm="clr-namespace:CartBuddy.ViewModels"
             xmlns:converters="clr-namespace:CartBuddy.Converters"
             xmlns:bottomsheet="http://pluginmauibottomsheet.com"
             x:Class="CartBuddy.LogsPage"
             x:Name="ThisPage"
             Title="API Logs"
             BackgroundColor="{AppThemeBinding Light={StaticResource Gray100}, Dark={StaticResource Gray950}}">

    <ContentPage.Resources>
        <converters:DirectionColorConverter x:Key="DirectionColorConverter" />
        <converters:DirectionGlyphConverter x:Key="DirectionGlyphConverter" />
    </ContentPage.Resources>

    <Grid RowDefinitions="*">
        <CollectionView x:Name="LogsList"
                        ItemsSource="{Binding Logs}"
                        SelectionMode="None"
                        Margin="0">
            <CollectionView.EmptyView>
                <VerticalStackLayout VerticalOptions="Center" HorizontalOptions="Center" Spacing="12" Padding="32">
                    <Label Text="No logs yet"
                           FontSize="16"
                           HorizontalOptions="Center"
                           TextColor="{StaticResource Gray400}" />
                    <Label Text="Make some API calls and refresh"
                           FontSize="13"
                           HorizontalOptions="Center"
                           TextColor="{StaticResource Gray400}" />
                </VerticalStackLayout>
            </CollectionView.EmptyView>
            <CollectionView.Header>
                <Grid Padding="16,12,16,8" ColumnDefinitions="*,Auto">
                    <Label Text="{Binding Logs.Count, StringFormat='{0} entries'}"
                           FontSize="13"
                           TextColor="{StaticResource Gray400}"
                           VerticalOptions="Center" />
                    <Button Grid.Column="1"
                            Text="Refresh"
                            Command="{Binding LoadLogsCommand}"
                            Padding="12,6"
                            FontSize="13"
                            CornerRadius="6" />
                </Grid>
            </CollectionView.Header>
            <CollectionView.ItemTemplate>
                <DataTemplate x:DataType="models:ApiLogEntry">
                    <Grid Padding="16,10,16,10"
                          ColumnDefinitions="Auto,*,Auto"
                          ColumnSpacing="10">
                        <Grid.GestureRecognizers>
                            <TapGestureRecognizer Tapped="OnEntryTapped" />
                        </Grid.GestureRecognizers>

                        <!-- Direction badge -->
                        <Border Grid.Column="0"
                                WidthRequest="24"
                                HeightRequest="24"
                                StrokeThickness="0"
                                VerticalOptions="Center"
                                BackgroundColor="{Binding Direction, Converter={StaticResource DirectionColorConverter}}">
                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="4" />
                            </Border.StrokeShape>
                            <Label Text="{Binding Direction, Converter={StaticResource DirectionGlyphConverter}}"
                                   FontFamily="FaSolid"
                                   FontSize="11"
                                   TextColor="White"
                                   HorizontalOptions="Center"
                                   VerticalOptions="Center" />
                        </Border>

                        <!-- Method + timestamp -->
                        <VerticalStackLayout Grid.Column="1" Spacing="2" VerticalOptions="Center">
                            <Label Text="{Binding MethodName}"
                                   FontSize="14"
                                   FontAttributes="Bold"
                                   LineBreakMode="TailTruncation" />
                            <Label Text="{Binding Timestamp, StringFormat='{0:MM/dd HH:mm:ss}'}"
                                   FontSize="11"
                                   TextColor="{StaticResource Gray400}" />
                        </VerticalStackLayout>

                        <!-- Chevron -->
                        <Label Grid.Column="2"
                               Text="&#xF054;"
                               FontFamily="FaSolid"
                               FontSize="12"
                               TextColor="{StaticResource Gray400}"
                               VerticalOptions="Center" />

                        <!-- Separator -->
                        <BoxView Grid.ColumnSpan="3"
                                 Grid.Row="1"
                                 HeightRequest="1"
                                 Margin="0,10,0,-10"
                                 BackgroundColor="{AppThemeBinding Light={StaticResource Gray200}, Dark={StaticResource Gray700}}" />
                    </Grid>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>

        <!-- Detail bottom sheet -->
        <bottomsheet:BottomSheet Grid.RowSpan="1"
                                 IsOpen="{Binding IsDetailOpen}"
                                 IsVisible="{Binding IsDetailOpen}"
                                 IsModal="True"
                                 IsCancelable="True"
                                 IsDraggable="True"
                                 HasHandle="True"
                                 ShowHeader="False"
                                 States="Medium,Large"
                                 CurrentState="Medium">
            <bottomsheet:BottomSheetContent>
                <bottomsheet:BottomSheetContent.ContentTemplate>
                    <DataTemplate>
                        <VerticalStackLayout Padding="16,12,16,16" Spacing="12">
                            <VerticalStackLayout Spacing="2">
                                <Label Text="{Binding SelectedEntry.MethodName}"
                                       FontSize="18"
                                       FontAttributes="Bold" />
                                <Label Text="{Binding SelectedEntry.Direction}"
                                       FontSize="12"
                                       TextColor="{StaticResource Gray400}" />
                                <Label Text="{Binding SelectedEntry.Timestamp, StringFormat='{0:yyyy-MM-dd HH:mm:ss} UTC'}"
                                       FontSize="12"
                                       TextColor="{StaticResource Gray400}" />
                            </VerticalStackLayout>

                            <ScrollView HeightRequest="380">
                                <Label Text="{Binding SelectedEntry.Payload}"
                                       FontSize="11"
                                       LineBreakMode="CharacterWrap" />
                            </ScrollView>
                        </VerticalStackLayout>
                    </DataTemplate>
                </bottomsheet:BottomSheetContent.ContentTemplate>
            </bottomsheet:BottomSheetContent>
        </bottomsheet:BottomSheet>
    </Grid>

</ContentPage>
