<?xml version="1.0" encoding="utf-8" ?>
<local:AppPopup xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
                xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
                xmlns:local="clr-namespace:CartBuddy"
                x:Class="CartBuddy.LogDetailPopup"
                CanBeDismissedByTappingOutsideOfPopup="True"
                Background="Transparent">

    <Border x:Name="PopupSurface"
            Style="{StaticResource PopupSurfaceBorder}">
        <VerticalStackLayout Padding="16" Spacing="10">
            <Label x:Name="MethodNameLabel"
                   FontSize="18"
                   FontAttributes="Bold" />

            <Label x:Name="MetadataLabel"
                   FontSize="13"
                   TextColor="{StaticResource Gray400}" />

                 <Label x:Name="DirectionLabel"
                     FontSize="12"
                     TextColor="{StaticResource Gray400}" />

                     <Label x:Name="EntryTypeLabel"
                         FontSize="12"
                         TextColor="{StaticResource Gray400}" />

                 <Button Text="Copy Payload"
                      Clicked="OnCopyPayloadClicked"
                      HorizontalOptions="Start"
                      Padding="12,8"
                      FontSize="13"
                      CornerRadius="8" />

            <ScrollView HeightRequest="320">
                <Label x:Name="PayloadLabel"
                       FontSize="12"
                       LineBreakMode="CharacterWrap" />
            </ScrollView>
        </VerticalStackLayout>
    </Border>
</local:AppPopup>
