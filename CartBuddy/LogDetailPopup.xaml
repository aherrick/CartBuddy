<?xml version="1.0" encoding="utf-8" ?>
<toolkit:Popup xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
               xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
               xmlns:toolkit="http://schemas.microsoft.com/dotnet/2022/maui/toolkit"
               xmlns:vm="clr-namespace:CartBuddy.ViewModels"
               xmlns:converters="clr-namespace:CartBuddy.Converters"
               x:Class="CartBuddy.LogDetailPopup"
               x:DataType="vm:LogsViewModel"
               CanBeDismissedByTappingOutsideOfPopup="True"
               HorizontalOptions="Fill"
               VerticalOptions="End"
               Background="Transparent">

    <toolkit:Popup.Resources>
        <converters:DirectionColorConverter x:Key="DirectionColorConverter" />
    </toolkit:Popup.Resources>

    <Border BackgroundColor="{AppThemeBinding Light={StaticResource White}, Dark={StaticResource Gray900}}"
            StrokeShape="RoundRectangle 16,16,0,0"
            Stroke="Transparent"
            Padding="0">
        <VerticalStackLayout Padding="16,12,16,32" Spacing="12">

            <!-- Title row -->
            <VerticalStackLayout Spacing="2">
                <Label Text="{Binding SelectedEntry.MethodName}"
                       FontSize="18"
                       FontAttributes="Bold" />
                <HorizontalStackLayout Spacing="8">
                    <Label Text="{Binding SelectedEntry.DirectionLabel}"
                           FontSize="13"
                           TextColor="{StaticResource Gray400}" />
                    <Label Text="•"
                           FontSize="13"
                           TextColor="{StaticResource Gray400}" />
                    <Label Text="{Binding SelectedEntry.Timestamp, StringFormat='{0:yyyy-MM-dd HH:mm:ss} UTC'}"
                           FontSize="13"
                           TextColor="{StaticResource Gray400}" />
                </HorizontalStackLayout>
            </VerticalStackLayout>

            <Button Text="Copy Payload"
                    Command="{Binding CopyEntryCommand}"
                    HorizontalOptions="Start"
                    Padding="12,8"
                    FontSize="13"
                    CornerRadius="8" />

            <ScrollView HeightRequest="380">
                <Border StrokeThickness="0"
                        Padding="12"
                        BackgroundColor="{AppThemeBinding Light={StaticResource Gray100}, Dark={StaticResource Gray800}}">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="12" />
                    </Border.StrokeShape>
                    <VerticalStackLayout Spacing="8">
                        <HorizontalStackLayout Spacing="8">
                            <Border Padding="8,4"
                                    StrokeThickness="0"
                                    BackgroundColor="{Binding SelectedEntry.Direction, Converter={StaticResource DirectionColorConverter}}">
                                <Border.StrokeShape>
                                    <RoundRectangle CornerRadius="999" />
                                </Border.StrokeShape>
                                <Label Text="{Binding SelectedEntry.DirectionLabel}"
                                       FontSize="11"
                                       TextColor="White" />
                            </Border>
                            <Label Text="{Binding SelectedEntry.Timestamp, StringFormat='{0:HH:mm:ss} UTC'}"
                                   FontSize="11"
                                   TextColor="{StaticResource Gray400}"
                                   VerticalOptions="Center" />
                        </HorizontalStackLayout>
                        <Label Text="{Binding SelectedEntry.Payload}"
                               FontSize="11"
                               LineBreakMode="CharacterWrap" />
                    </VerticalStackLayout>
                </Border>
            </ScrollView>

        </VerticalStackLayout>
    </Border>
</toolkit:Popup>
