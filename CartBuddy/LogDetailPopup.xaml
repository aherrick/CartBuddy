<?xml version="1.0" encoding="utf-8" ?>
<local:AppPopup xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
                xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
                xmlns:local="clr-namespace:CartBuddy"
                x:Class="CartBuddy.LogDetailPopup"
                CanBeDismissedByTappingOutsideOfPopup="True"
                Background="Transparent">

    <Border x:Name="PopupSurface"
            Style="{StaticResource PopupSurfaceBorder}">
        <VerticalStackLayout Padding="16" Spacing="10">
            <Label x:Name="MethodNameLabel"
                   FontSize="18"
                   FontAttributes="Bold" />

            <Label x:Name="MetadataLabel"
                   FontSize="13"
                   TextColor="{StaticResource Gray400}" />

            <ScrollView HeightRequest="320">
                <Border Padding="12"
                        StrokeThickness="0"
                        BackgroundColor="{AppThemeBinding Light={StaticResource Gray100}, Dark={StaticResource Gray800}}">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="12" />
                    </Border.StrokeShape>
                    <Label x:Name="PayloadLabel"
                           FontSize="12"
                           LineBreakMode="CharacterWrap" />
                </Border>
            </ScrollView>
        </VerticalStackLayout>
    </Border>
</local:AppPopup>
