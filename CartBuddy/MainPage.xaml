<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:models="clr-namespace:CartBuddy.Models"
             xmlns:vm="clr-namespace:CartBuddy.ViewModels"
             xmlns:controls="clr-namespace:CartBuddy.Controls"
             xmlns:bottomsheet="http://pluginmauibottomsheet.com"
             x:Class="CartBuddy.MainPage"
             x:Name="ThisPage"
             Title="Cart Buddy"
             BackgroundColor="{AppThemeBinding Light={StaticResource Gray100}, Dark={StaticResource Gray950}}">

    <ContentPage.ToolbarItems>
        <ToolbarItem Clicked="OnCartClicked" Order="Primary" Priority="0">
            <ToolbarItem.IconImageSource>
                <FontImageSource FontFamily="FaSolid"
                                 Glyph="&#xF07A;"
                                 Size="18"
                                 Color="{AppThemeBinding Light={StaticResource Gray950}, Dark={StaticResource Gray100}}" />
            </ToolbarItem.IconImageSource>
        </ToolbarItem>
        <ToolbarItem Clicked="OnMenuClicked" Order="Primary" Priority="1">
            <ToolbarItem.IconImageSource>
                <FontImageSource FontFamily="FaSolid"
                                 Glyph="&#xF0C9;"
                                 Size="18"
                                 Color="{AppThemeBinding Light={StaticResource Gray950}, Dark={StaticResource Gray100}}" />
            </ToolbarItem.IconImageSource>
        </ToolbarItem>
    </ContentPage.ToolbarItems>

    <Grid RowDefinitions="Auto,*">
        <VerticalStackLayout Padding="16,14,16,14" Spacing="14">
            <VerticalStackLayout Spacing="10">
                <Grid ColumnDefinitions="*,Auto,Auto" ColumnSpacing="10">
                    <VerticalStackLayout Spacing="2" VerticalOptions="Center">
                        <Label Text="Shopping List" FontSize="22" FontAttributes="Bold" />
                        <Label Text="{Binding ItemsSummary}"
                               FontSize="12"
                               LineBreakMode="WordWrap"
                               TextColor="{StaticResource Gray400}" />
                    </VerticalStackLayout>
                    <Button Grid.Column="1"
                            Text="{Binding ItemsEditorToggleText}"
                            Command="{Binding ToggleItemsEditorCommand}"
                            IsVisible="{Binding CanToggleItemsEditor}"
                            Padding="12,8"
                            FontSize="12"
                            CornerRadius="6"
                            VerticalOptions="Center"
                            TextColor="{AppThemeBinding Light={StaticResource Gray950}, Dark={StaticResource Gray100}}"
                            BackgroundColor="{AppThemeBinding Light={StaticResource Gray200}, Dark={StaticResource Gray900}}" />
                    <Button Grid.Column="2"
                            Clicked="OnClearSearchClicked"
                            IsVisible="{Binding HasItemsText}"
                            Padding="12,8"
                            WidthRequest="48"
                            CornerRadius="6"
                            VerticalOptions="Center"
                            BackgroundColor="{StaticResource SaleRed}"
                            Text="&#xF1F8;"
                            FontFamily="FaSolid"
                            FontSize="14"
                            TextColor="{StaticResource White}" />
                </Grid>

                <VerticalStackLayout IsVisible="{Binding IsItemsEditorVisible}" Spacing="10">
                    <Border Stroke="{AppThemeBinding Light={StaticResource Gray200}, Dark={StaticResource Gray600}}"
                            StrokeThickness="1"
                            StrokeShape="RoundRectangle 8"
                            BackgroundColor="{AppThemeBinding Light={StaticResource White}, Dark={StaticResource OffBlack}}"
                            Padding="8">
                        <Editor x:Name="RawItemsEditor"
                                Text="{Binding RawItemsText}"
                                Placeholder="apples&#10;spinach&#10;pizza&#10;beer"
                                HeightRequest="140"
                                MinimumHeightRequest="120"
                                AutoSize="Disabled" />
                    </Border>

                    <Button Text="Search"
                            Clicked="OnSearchClicked"
                            HorizontalOptions="Start"
                            CornerRadius="6" />
                </VerticalStackLayout>
            </VerticalStackLayout>

        </VerticalStackLayout>

        <CollectionView Grid.Row="1"
                        Margin="16,0,16,16"
                        ItemsSource="{Binding SearchGroups}"
                        IsGrouped="True"
                        SelectionMode="None"
                        ItemSizingStrategy="MeasureAllItems"
                        VerticalScrollBarVisibility="Never"
                        VerticalOptions="Fill"
                        IsVisible="{Binding HasResults}">
            <CollectionView.GroupHeaderTemplate>
                <DataTemplate x:DataType="models:SearchGroup">
                    <VerticalStackLayout Padding="0,12,0,0"
                                         Spacing="8"
                                         BackgroundColor="{AppThemeBinding Light={StaticResource Gray100}, Dark={StaticResource Gray950}}">
                        <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8">
                            <VerticalStackLayout Spacing="2">
                                <HorizontalStackLayout Spacing="6">
                                    <Label Text="{Binding Query}" FontSize="17" FontAttributes="Bold" />
                                    <Label Text="&#xF058;"
                                           FontFamily="FaSolid"
                                           FontSize="14"
                                           TextColor="{StaticResource SaleGreen}"
                                           IsVisible="{Binding IsCompleted}"
                                           VerticalOptions="Center" />
                                </HorizontalStackLayout>
                                <Label Text="{Binding PageSummary}" FontSize="12"
                                       TextColor="{StaticResource Gray400}" />
                            </VerticalStackLayout>
                            <Button Grid.Column="1"
                                    Text="View More"
                                    IsVisible="{Binding HasMore}"
                                    Command="{Binding Source={RelativeSource AncestorType={x:Type vm:MainViewModel}}, Path=ViewMoreCommand}"
                                    CommandParameter="{Binding}"
                                    Padding="12,8"
                                    FontSize="12"
                                    CornerRadius="6" />
                        </Grid>

                        <Label Text="No Kroger matches found for this item."
                               IsVisible="{Binding IsEmpty}"
                               FontSize="13"
                               TextColor="{StaticResource Gray400}" />

                        <BoxView HeightRequest="1"
                                 BackgroundColor="{AppThemeBinding Light={StaticResource Gray200}, Dark={StaticResource Gray600}}"
                                 IsVisible="{Binding HasMatches}" />
                    </VerticalStackLayout>
                </DataTemplate>
            </CollectionView.GroupHeaderTemplate>
            <CollectionView.ItemTemplate>
                <DataTemplate x:DataType="models:ProductMatch">
                    <controls:ProductListItemView
                        Title="{Binding Description}"
                        Subtitle="{Binding Brand}"
                        Detail="{Binding Size}"
                        ImageUrl="{Binding ImageUrl}"
                        PriceText="{Binding Price, StringFormat='${0:F2}'}"
                        SecondaryPriceText="{Binding RegularPriceDisplay}"
                        AccentText="{Binding PromoEndDisplay}"
                        AccentColor="{StaticResource SaleRed}"
                        ShowPriceBadge="{Binding HasSale}"
                        PriceBadgeColor="{StaticResource SaleGreen}"
                        ItemCommand="{Binding Source={RelativeSource AncestorType={x:Type vm:MainViewModel}}, Path=AddToCartCommand}"
                        ItemCommandParameter="{Binding}"
                        PriceColor="{AppThemeBinding Light={StaticResource Gray950}, Dark={StaticResource Gray100}}" />
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>

        <ActivityIndicator Grid.RowSpan="2"
                           IsRunning="{Binding IsBusy}"
                           IsVisible="{Binding IsBusy}"
                           HeightRequest="20"
                           WidthRequest="20"
                           HorizontalOptions="Center"
                           VerticalOptions="Center" />

        <Border IsVisible="{Binding IsSnackbarVisible}"
                VerticalOptions="Start"
                Margin="16,12,16,0"
                Padding="14,12"
                StrokeThickness="0"
                ZIndex="2"
                BackgroundColor="{AppThemeBinding Light={StaticResource Gray950}, Dark={StaticResource Gray900}}">
            <Label Text="{Binding SnackbarMessage}"
                   TextColor="{StaticResource White}"
                   FontSize="13"
                   LineBreakMode="TailTruncation" />
        </Border>

        <bottomsheet:BottomSheet Grid.RowSpan="2"
                                 IsOpen="{Binding IsCartOpen}"
                                 IsVisible="{Binding IsCartOpen}"
                                 IsModal="True"
                                 IsCancelable="True"
                                 IsDraggable="True"
                                 HasHandle="True"
                                 ShowHeader="False"
                                 States="Medium,Large"
                                 CurrentState="Medium">
            <bottomsheet:BottomSheetContent>
                <bottomsheet:BottomSheetContent.ContentTemplate>
                    <DataTemplate>
                        <VerticalStackLayout Padding="10,10,10,12" Spacing="12">
                            <VerticalStackLayout Spacing="2">
                                <Label Text="Cart" FontSize="22" FontAttributes="Bold" />
                                <Label Text="{Binding CartSummary}" FontSize="13" TextColor="{StaticResource Gray400}" />
                            </VerticalStackLayout>

                            <Grid ColumnDefinitions="*,Auto" ColumnSpacing="10" IsVisible="{Binding HasCartItems}">
                                <Button Text="Checkout" Command="{Binding CheckoutCommand}" />
                                <Button Grid.Column="1"
                                        Clicked="OnClearCartClicked"
                                        Padding="12,8"
                                        WidthRequest="48"
                                        BackgroundColor="{StaticResource SaleRed}"
                                        Text="&#xF1F8;"
                                        FontFamily="FaSolid"
                                        FontSize="14"
                                        TextColor="{StaticResource White}" />
                            </Grid>

                            <CollectionView ItemsSource="{Binding CartItems}"
                                            SelectionMode="None"
                                            HeightRequest="420"
                                            VerticalScrollBarVisibility="Never">
                                <CollectionView.EmptyView>
                                    <Label Text="Your cart is empty" FontSize="14" HorizontalOptions="Center"
                                           TextColor="{StaticResource Gray400}" />
                                </CollectionView.EmptyView>
                                <CollectionView.ItemTemplate>
                                    <DataTemplate x:DataType="models:CartLine">
                                        <controls:ProductListItemView
                                            Title="{Binding Description}"
                                            Subtitle="{Binding Price, StringFormat='${0:F2} each'}"
                                            ImageUrl="{Binding ImageUrl}"
                                            PriceText="{Binding LineTotal, StringFormat='${0:F2}'}"
                                            PriceColor="{AppThemeBinding Light={StaticResource Gray950}, Dark={StaticResource Gray100}}"
                                            ShowQuantityControls="True"
                                            Quantity="{Binding Quantity}"
                                            IncreaseCommand="{Binding Source={RelativeSource AncestorType={x:Type vm:MainViewModel}}, Path=IncreaseQuantityCommand}"
                                            DecreaseCommand="{Binding Source={RelativeSource AncestorType={x:Type vm:MainViewModel}}, Path=DecreaseQuantityCommand}"
                                            QuantityCommandParameter="{Binding}" />
                                    </DataTemplate>
                                </CollectionView.ItemTemplate>
                            </CollectionView>
                        </VerticalStackLayout>
                    </DataTemplate>
                </bottomsheet:BottomSheetContent.ContentTemplate>
            </bottomsheet:BottomSheetContent>
        </bottomsheet:BottomSheet>
    </Grid>
</ContentPage>
