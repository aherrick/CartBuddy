<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:models="clr-namespace:CartBuddy.Models"
             xmlns:vm="clr-namespace:CartBuddy.ViewModels"
             xmlns:local="clr-namespace:CartBuddy"
             xmlns:controls="clr-namespace:CartBuddy.Controls"
             xmlns:converters="clr-namespace:CartBuddy.Converters"
             xmlns:sfListView="clr-namespace:Syncfusion.Maui.ListView;assembly=Syncfusion.Maui.ListView"
             xmlns:toolkit="http://schemas.microsoft.com/dotnet/2022/maui/toolkit"
             x:Class="CartBuddy.MainPage"
             x:Name="ThisPage"
             Title="Cart Buddy"
             BackgroundColor="{AppThemeBinding Light={StaticResource Gray100}, Dark={StaticResource Gray950}}">

    <ContentPage.Behaviors>
        <toolkit:StatusBarBehavior StatusBarColor="{AppThemeBinding Light={StaticResource Gray100}, Dark={StaticResource Gray950}}" StatusBarStyle="{AppThemeBinding Light=DarkContent, Dark=LightContent}" />
    </ContentPage.Behaviors>

    <ContentPage.Resources>
        <converters:ExpandIconConverter x:Key="ExpandIconConverter" />
        <converters:ExpandAllTextConverter x:Key="ExpandAllTextConverter" />
        <converters:GroupInfoConverter x:Key="GroupInfoConverter" />
        <toolkit:InvertedBoolConverter x:Key="InvertedBoolConverter" />
    </ContentPage.Resources>

    <ContentPage.ToolbarItems>
        <ToolbarItem Clicked="OnCartClicked" Order="Primary" Priority="0">
            <ToolbarItem.IconImageSource>
                <FontImageSource FontFamily="FaSolid"
                                 Glyph="&#xF07A;"
                                 Size="18"
                                 Color="{Binding CartIconColor}" />
            </ToolbarItem.IconImageSource>
        </ToolbarItem>
        <ToolbarItem Clicked="OnMenuClicked" Order="Primary" Priority="1">
            <ToolbarItem.IconImageSource>
                <FontImageSource FontFamily="FaSolid"
                                 Glyph="&#xF0C9;"
                                 Size="18"
                                 Color="{AppThemeBinding Light={StaticResource Gray950}, Dark={StaticResource Gray100}}" />
            </ToolbarItem.IconImageSource>
        </ToolbarItem>
    </ContentPage.ToolbarItems>

    <Grid RowDefinitions="Auto,*">
        <VerticalStackLayout Padding="16,14,16,14" Spacing="14">
            <VerticalStackLayout Spacing="10">
                <Grid ColumnDefinitions="*,Auto,Auto" ColumnSpacing="10">
                    <VerticalStackLayout Spacing="2" VerticalOptions="Center">
                        <Label Text="Shopping List" FontSize="22" FontAttributes="Bold" />
                        <Label Text="{Binding ItemsSummary}"
                               FontSize="13"
                               LineBreakMode="WordWrap"
                               TextColor="{StaticResource Gray400}" />
                    </VerticalStackLayout>
                    <Button Grid.Column="1"
                            Text="{Binding ItemsEditorToggleText}"
                            Command="{Binding ToggleItemsEditorCommand}"
                            IsVisible="{Binding CanToggleItemsEditor}"
                            Padding="12,8"
                            FontSize="13"
                            CornerRadius="6"
                            VerticalOptions="Center" />
                    <Button Grid.Column="2"
                            Clicked="OnClearSearchClicked"
                            IsVisible="{Binding HasItemsText}"
                            Padding="12,8"
                            WidthRequest="48"
                            CornerRadius="6"
                            VerticalOptions="Center"
                            BackgroundColor="{StaticResource SaleRed}"
                            Text="&#xF1F8;"
                            FontFamily="FaSolid"
                            FontSize="14"
                            SemanticProperties.Description="Clear shopping list"
                            SemanticProperties.Hint="Removes the current list and search results"
                            TextColor="{StaticResource White}" />
                </Grid>

                <BoxView HeightRequest="1"
                         IsVisible="{Binding IsItemsEditorVisible, Converter={StaticResource InvertedBoolConverter}}"
                         BackgroundColor="{AppThemeBinding Light={StaticResource Gray200}, Dark={StaticResource Gray600}}" />

                <VerticalStackLayout IsVisible="{Binding IsItemsEditorVisible}" Spacing="10">
                    <Border Stroke="{AppThemeBinding Light={StaticResource Gray200}, Dark={StaticResource Gray600}}"
                            StrokeThickness="1"
                            StrokeShape="RoundRectangle 8"
                            BackgroundColor="{AppThemeBinding Light={StaticResource White}, Dark={StaticResource OffBlack}}"
                            Padding="8">
                        <Editor x:Name="RawItemsEditor"
                                Text="{Binding RawItemsText}"
                                Placeholder="apples&#10;spinach&#10;pizza&#10;beer"
                                HeightRequest="140"
                                MinimumHeightRequest="120"
                                AutoSize="Disabled" />
                    </Border>

                                <HorizontalStackLayout Spacing="10">
                                <Button Text="&#xF0D0;"
                                    Command="{Binding RunAiCleanupCommand}"
                                    WidthRequest="48"
                                    FontFamily="FaSolid"
                                    FontSize="14"
                                    HorizontalOptions="Start"
                                    CornerRadius="6"
                                    SemanticProperties.Description="Run AI cleanup"
                                    SemanticProperties.Hint="Cleans the shopping list before search" />
                            <Button Text="Search"
                                Command="{Binding SearchCommand}"
                                HorizontalOptions="Start"
                                CornerRadius="6" />
                            </HorizontalStackLayout>
                </VerticalStackLayout>
            </VerticalStackLayout>

            <Button Text="{Binding AllGroupsExpanded, Converter={StaticResource ExpandAllTextConverter}}"
                    Clicked="OnToggleExpandAll"
                    IsVisible="{Binding HasResults}"
                    HorizontalOptions="End"
                    Padding="12,8"
                    FontSize="13"
                    CornerRadius="6" />

        </VerticalStackLayout>

        <sfListView:SfListView x:Name="SearchListView"
                               Grid.Row="1"
                               Margin="0,0,0,0"
                               ItemsSource="{Binding AllProducts}"
                               SelectionMode="None"
                               AutoFitMode="Height"
                               GroupHeaderSize="58"
                               AllowGroupExpandCollapse="True"
                               IsStickyGroupHeader="True"
                               IsVisible="{Binding HasResults}">
            <sfListView:SfListView.GroupHeaderTemplate>
                <DataTemplate>
                    <Grid BackgroundColor="{AppThemeBinding Light={StaticResource Gray100}, Dark={StaticResource Gray950}}"
                          Padding="16,10,16,10"
                          ColumnDefinitions="Auto,*,Auto,Auto"
                          ColumnSpacing="8">
                        <Label Grid.Column="0"
                               Text="{Binding IsExpand, Converter={StaticResource ExpandIconConverter}}"
                               FontFamily="FaSolid"
                               FontSize="13"
                               TextColor="{AppThemeBinding Light={StaticResource Gray500}, Dark={StaticResource Gray400}}"
                               VerticalOptions="Center" />
                        <HorizontalStackLayout Grid.Column="1" Spacing="6" VerticalOptions="Center">
                            <Label Text="{Binding Key}"
                                   FontSize="17"
                                   FontAttributes="Bold" />
                            <Label Text="&#xF058;"
                                   FontFamily="FaSolid"
                                   FontSize="14"
                                   TextColor="{StaticResource SaleGreen}"
                                   VerticalOptions="Center">
                                <Label.IsVisible>
                                    <MultiBinding Converter="{StaticResource GroupInfoConverter}" ConverterParameter="IsCompleted">
                                        <Binding Path="Key" />
                                        <Binding Source="{x:Reference ThisPage}" Path="BindingContext.SearchGroups" />
                                        <Binding Source="{x:Reference ThisPage}" Path="BindingContext.GroupStateVersion" />
                                    </MultiBinding>
                                </Label.IsVisible>
                            </Label>
                        </HorizontalStackLayout>
                        <Label Grid.Column="2"
                               FontSize="13"
                               TextColor="{StaticResource Gray400}"
                               VerticalOptions="Center">
                            <Label.Text>
                                <MultiBinding Converter="{StaticResource GroupInfoConverter}" ConverterParameter="PageSummary">
                                    <Binding Path="Key" />
                                    <Binding Source="{x:Reference ThisPage}" Path="BindingContext.SearchGroups" />
                                    <Binding Source="{x:Reference ThisPage}" Path="BindingContext.GroupStateVersion" />
                                </MultiBinding>
                            </Label.Text>
                        </Label>
                        <Button Grid.Column="3"
                                Text="View More"
                                Command="{Binding Source={x:Reference ThisPage}, Path=ViewMoreCommand}"
                                Padding="12,6"
                                FontSize="13"
                                CornerRadius="6">
                            <Button.CommandParameter>
                                <MultiBinding Converter="{StaticResource GroupInfoConverter}" ConverterParameter="Group">
                                    <Binding Path="Key" />
                                    <Binding Source="{x:Reference ThisPage}" Path="BindingContext.SearchGroups" />
                                    <Binding Source="{x:Reference ThisPage}" Path="BindingContext.GroupStateVersion" />
                                </MultiBinding>
                            </Button.CommandParameter>
                            <Button.IsVisible>
                                <MultiBinding Converter="{StaticResource GroupInfoConverter}" ConverterParameter="HasMore">
                                    <Binding Path="Key" />
                                    <Binding Source="{x:Reference ThisPage}" Path="BindingContext.SearchGroups" />
                                    <Binding Source="{x:Reference ThisPage}" Path="BindingContext.GroupStateVersion" />
                                </MultiBinding>
                            </Button.IsVisible>
                        </Button>
                    </Grid>
                </DataTemplate>
            </sfListView:SfListView.GroupHeaderTemplate>
            <sfListView:SfListView.ItemTemplate>
                <DataTemplate x:DataType="models:ProductMatch">
                    <Grid>
                        <controls:ProductListItemView
                            IsVisible="{Binding IsNoResult, Converter={StaticResource InvertedBoolConverter}}"
                            Margin="16,0"
                            Title="{Binding Description}"
                            Subtitle="{Binding DisplayBrand}"
                            Detail="{Binding Size}"
                            ImageUrl="{Binding ImageUrl}"
                            PriceText="{Binding PriceDisplay}"
                            SecondaryPriceText="{Binding RegularPriceDisplay}"
                            AccentText="{Binding PromoEndDisplay}"
                            AccentColor="{StaticResource SaleRed}"
                            ShowPriceBadge="{Binding HasSale}"
                            PriceBadgeColor="{StaticResource SaleGreen}"
                            ItemCommand="{Binding AddToCartCommand, Source={RelativeSource AncestorType={x:Type local:MainPage}}}"
                            ItemCommandParameter="{Binding}"
                            PriceColor="{AppThemeBinding Light={StaticResource Gray950}, Dark={StaticResource Gray100}}" />
                        <Label IsVisible="{Binding IsNoResult}"
                               Text="{Binding NoResultMessage}"
                               Margin="16,12"
                               FontSize="14"
                               TextColor="{StaticResource Gray400}" />
                    </Grid>
                </DataTemplate>
            </sfListView:SfListView.ItemTemplate>
        </sfListView:SfListView>

        <ActivityIndicator Grid.RowSpan="2"
                           IsRunning="{Binding IsBusy}"
                           IsVisible="{Binding IsBusy}"
                           HeightRequest="20"
                           WidthRequest="20"
                           HorizontalOptions="Center"
                           VerticalOptions="Center" />

    </Grid>
</ContentPage>
