<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="CartBuddy.MainPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:controls="clr-namespace:CartBuddy.Controls"
    xmlns:converters="clr-namespace:CartBuddy.Converters"
    xmlns:local="clr-namespace:CartBuddy"
    xmlns:models="clr-namespace:CartBuddy.Models"
    xmlns:sfListView="clr-namespace:Syncfusion.Maui.ListView;assembly=Syncfusion.Maui.ListView"
    xmlns:toolkit="http://schemas.microsoft.com/dotnet/2022/maui/toolkit"
    xmlns:vm="clr-namespace:CartBuddy.ViewModels"
    x:Name="ThisPage"
    Title="Cart Buddy"
    BackgroundColor="{AppThemeBinding Light={StaticResource Gray100},
                                      Dark={StaticResource Gray950}}">

    <ContentPage.Behaviors>
        <toolkit:StatusBarBehavior StatusBarColor="{AppThemeBinding Light={StaticResource Gray100}, Dark={StaticResource Gray950}}" StatusBarStyle="{AppThemeBinding Light=DarkContent, Dark=LightContent}" />
    </ContentPage.Behaviors>

    <ContentPage.Resources>
        <converters:ExpandIconConverter x:Key="ExpandIconConverter" />
        <converters:ExpandAllTextConverter x:Key="ExpandAllTextConverter" />
        <converters:GroupInfoConverter x:Key="GroupInfoConverter" />
        <toolkit:InvertedBoolConverter x:Key="InvertedBoolConverter" />
    </ContentPage.Resources>

    <ContentPage.ToolbarItems>
        <ToolbarItem
            Clicked="OnCartClicked"
            Order="Primary"
            Priority="0">
            <ToolbarItem.IconImageSource>
                <FontImageSource
                    FontFamily="FaSolid"
                    Glyph="&#xF07A;"
                    Size="18"
                    Color="{Binding CartIconColor}" />
            </ToolbarItem.IconImageSource>
        </ToolbarItem>
        <ToolbarItem
            Clicked="OnMenuClicked"
            Order="Primary"
            Priority="1">
            <ToolbarItem.IconImageSource>
                <FontImageSource
                    FontFamily="FaSolid"
                    Glyph="&#xF0C9;"
                    Size="18"
                    Color="{AppThemeBinding Light={StaticResource Gray950},
                                            Dark={StaticResource Gray100}}" />
            </ToolbarItem.IconImageSource>
        </ToolbarItem>
    </ContentPage.ToolbarItems>

    <Grid RowDefinitions="Auto,*">
        <BoxView
            x:Name="SnackbarAnchor"
            Grid.Row="0"
            Margin="0,62,0,0"
            HeightRequest="1"
            Opacity="0"
            VerticalOptions="Start" />
        <VerticalStackLayout
            Grid.Row="0"
            Padding="16,14,16,14"
            x:DataType="vm:MainViewModel"
            Spacing="14">
            <VerticalStackLayout Spacing="10">
                <Grid ColumnDefinitions="*,Auto,Auto" ColumnSpacing="10">
                    <VerticalStackLayout Spacing="2" VerticalOptions="Center">
                        <Label
                            FontAttributes="Bold"
                            FontSize="22"
                            Text="Shopping List" />
                        <Label
                            FontSize="13"
                            LineBreakMode="WordWrap"
                            Text="{Binding ItemsSummary}"
                            TextColor="{StaticResource Gray400}" />
                    </VerticalStackLayout>
                    <Button
                        Grid.Column="1"
                        Padding="12,8"
                        Command="{Binding ToggleItemsEditorCommand}"
                        CornerRadius="6"
                        FontSize="13"
                        IsVisible="{Binding CanToggleItemsEditor}"
                        Text="{Binding ItemsEditorToggleText}"
                        VerticalOptions="Center" />
                    <Button
                        Grid.Column="2"
                        Padding="12,8"
                        BackgroundColor="{StaticResource SaleRed}"
                        Clicked="OnClearSearchClicked"
                        CornerRadius="6"
                        FontFamily="FaSolid"
                        FontSize="14"
                        IsVisible="{Binding HasItemsText}"
                        SemanticProperties.Description="Clear shopping list"
                        SemanticProperties.Hint="Removes the current list and search results"
                        Text="&#xF1F8;"
                        TextColor="{StaticResource White}"
                        VerticalOptions="Center"
                        WidthRequest="48" />
                </Grid>

                <BoxView
                    BackgroundColor="{AppThemeBinding Light={StaticResource Gray200},
                                                      Dark={StaticResource Gray600}}"
                    HeightRequest="1"
                    IsVisible="{Binding IsItemsEditorVisible, Converter={StaticResource InvertedBoolConverter}}" />

                <VerticalStackLayout IsVisible="{Binding IsItemsEditorVisible}" Spacing="10">
                    <Border
                        Padding="8"
                        BackgroundColor="{AppThemeBinding Light={StaticResource White},
                                                          Dark={StaticResource OffBlack}}"
                        Stroke="{AppThemeBinding Light={StaticResource Gray200},
                                                 Dark={StaticResource Gray600}}"
                        StrokeShape="RoundRectangle 8"
                        StrokeThickness="1">
                        <Editor
                            x:Name="RawItemsEditor"
                            AutoSize="Disabled"
                            HeightRequest="140"
                            MinimumHeightRequest="120"
                            Placeholder="apples&#10;spinach&#10;pizza&#10;beer"
                            Text="{Binding RawItemsText}" />
                    </Border>

                    <HorizontalStackLayout Spacing="10">
                        <Button
                            Command="{Binding SearchCommand}"
                            CornerRadius="6"
                            HorizontalOptions="Start"
                            Text="Search">
                            <Button.ImageSource>
                                <FontImageSource
                                    FontFamily="FaSolid"
                                    Glyph="&#xF002;"
                                    Size="14" />
                            </Button.ImageSource>
                        </Button>
                    </HorizontalStackLayout>
                </VerticalStackLayout>
            </VerticalStackLayout>

            <Button
                Padding="12,8"
                Clicked="OnToggleExpandAll"
                CornerRadius="6"
                FontSize="13"
                HorizontalOptions="End"
                IsVisible="{Binding HasResults}"
                Text="{Binding AllGroupsExpanded, Converter={StaticResource ExpandAllTextConverter}}" />
        </VerticalStackLayout>

        <sfListView:SfListView
            x:Name="SearchListView"
            Grid.Row="1"
            Margin="0,0,0,0"
            AllowGroupExpandCollapse="True"
            AutoFitMode="Height"
            GroupHeaderSize="58"
            IsStickyGroupHeader="True"
            IsVisible="{Binding HasResults}"
            ItemsSource="{Binding AllProducts}"
            SelectionMode="None">
            <sfListView:SfListView.GroupHeaderTemplate>
                <DataTemplate x:DataType="{x:Null}">
                    <Grid
                        Padding="16,10,16,10"
                        BackgroundColor="{AppThemeBinding Light={StaticResource Gray100},
                                                          Dark={StaticResource Gray950}}"
                        ColumnDefinitions="Auto,*,Auto,Auto"
                        ColumnSpacing="8">
                        <Label
                            Grid.Column="0"
                            FontFamily="FaSolid"
                            FontSize="13"
                            Text="{Binding IsExpand, Converter={StaticResource ExpandIconConverter}}"
                            TextColor="{AppThemeBinding Light={StaticResource Gray500},
                                                        Dark={StaticResource Gray400}}"
                            VerticalOptions="Center" />
                        <HorizontalStackLayout
                            Grid.Column="1"
                            Spacing="6"
                            VerticalOptions="Center">
                            <Label
                                FontAttributes="Bold"
                                FontSize="17"
                                Text="{Binding Key}" />
                            <Label
                                FontFamily="FaSolid"
                                FontSize="14"
                                Text="&#xF058;"
                                TextColor="{StaticResource SaleGreen}"
                                VerticalOptions="Center">
                                <Label.IsVisible>
                                    <MultiBinding Converter="{StaticResource GroupInfoConverter}" ConverterParameter="IsCompleted">
                                        <Binding Path="Key" />
                                        <Binding Path="BindingContext.SearchGroups" Source="{x:Reference ThisPage}" />
                                        <Binding Path="BindingContext.GroupStateVersion" Source="{x:Reference ThisPage}" />
                                    </MultiBinding>
                                </Label.IsVisible>
                            </Label>
                        </HorizontalStackLayout>
                        <Label
                            Grid.Column="2"
                            FontSize="13"
                            TextColor="{StaticResource Gray400}"
                            VerticalOptions="Center">
                            <Label.Text>
                                <MultiBinding Converter="{StaticResource GroupInfoConverter}" ConverterParameter="PageSummary">
                                    <Binding Path="Key" />
                                    <Binding Path="BindingContext.SearchGroups" Source="{x:Reference ThisPage}" />
                                    <Binding Path="BindingContext.GroupStateVersion" Source="{x:Reference ThisPage}" />
                                </MultiBinding>
                            </Label.Text>
                        </Label>
                        <Button
                            Grid.Column="3"
                            Padding="12,6"
                            Command="{Binding Source={x:Reference ThisPage}, Path=ViewMoreCommand}"
                            CornerRadius="6"
                            FontSize="13"
                            Text="View More">
                            <Button.CommandParameter>
                                <MultiBinding Converter="{StaticResource GroupInfoConverter}" ConverterParameter="Group">
                                    <Binding Path="Key" />
                                    <Binding Path="BindingContext.SearchGroups" Source="{x:Reference ThisPage}" />
                                    <Binding Path="BindingContext.GroupStateVersion" Source="{x:Reference ThisPage}" />
                                </MultiBinding>
                            </Button.CommandParameter>
                            <Button.IsVisible>
                                <MultiBinding Converter="{StaticResource GroupInfoConverter}" ConverterParameter="HasMore">
                                    <Binding Path="Key" />
                                    <Binding Path="BindingContext.SearchGroups" Source="{x:Reference ThisPage}" />
                                    <Binding Path="BindingContext.GroupStateVersion" Source="{x:Reference ThisPage}" />
                                </MultiBinding>
                            </Button.IsVisible>
                        </Button>
                    </Grid>
                </DataTemplate>
            </sfListView:SfListView.GroupHeaderTemplate>
            <sfListView:SfListView.ItemTemplate>
                <DataTemplate x:DataType="models:ProductMatch">
                    <Grid>
                        <controls:ProductListItemView
                            Title="{Binding Description}"
                            Margin="16,0"
                            AccentColor="{StaticResource SaleRed}"
                            AccentText="{Binding PromoEndDisplay}"
                            Detail="{Binding Size}"
                            ImageUrl="{Binding ImageUrl}"
                            IsVisible="{Binding IsNoResult, Converter={StaticResource InvertedBoolConverter}}"
                            ItemCommand="{Binding AddToCartCommand, Source={RelativeSource AncestorType={x:Type local:MainPage}}}"
                            ItemCommandParameter="{Binding}"
                            PriceBadgeColor="{StaticResource SaleGreen}"
                            PriceColor="{AppThemeBinding Light={StaticResource Gray950},
                                                         Dark={StaticResource Gray100}}"
                            PriceText="{Binding PriceDisplay}"
                            SecondaryPriceStrikethrough="{Binding RegularPriceDisplayIsStrikethrough}"
                            SecondaryPriceText="{Binding RegularPriceDisplay}"
                            ShowPriceBadge="{Binding HasSale}"
                            Subtitle="{Binding DisplayBrand}" />
                        <Label
                            Margin="16,12"
                            FontSize="14"
                            IsVisible="{Binding IsNoResult}"
                            Text="{Binding NoResultMessage}"
                            TextColor="{StaticResource Gray400}" />
                    </Grid>
                </DataTemplate>
            </sfListView:SfListView.ItemTemplate>
        </sfListView:SfListView>

        <ActivityIndicator
            Grid.RowSpan="2"
            HeightRequest="20"
            HorizontalOptions="Center"
            IsRunning="{Binding IsBusy}"
            IsVisible="{Binding IsBusy}"
            VerticalOptions="Center"
            WidthRequest="20" />
    </Grid>
</ContentPage>