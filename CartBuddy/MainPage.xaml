<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="CartBuddy.MainPage"
             Title="Cart Buddy"
             BackgroundColor="{AppThemeBinding Light=White, Dark=Black}">
    <ScrollView>
        <VerticalStackLayout Padding="16" Spacing="14">
            <Label Text="MainPage standalone"
                   FontSize="24"
                   FontAttributes="Bold"
                   TextColor="{AppThemeBinding Light=Black, Dark=White}" />

            <Label Text="No view model attached"
                   FontSize="14"
                   TextColor="{AppThemeBinding Light=Black, Dark=White}" />

            <Label Text="If this still crashes, the problem is outside MainPage binding logic."
                   FontSize="14"
                   LineBreakMode="WordWrap"
                   TextColor="{AppThemeBinding Light=Black, Dark=White}" />

            <Editor Placeholder="milk&#10;cheese&#10;water"
                    HeightRequest="140"
                    AutoSize="TextChanges"
                    BackgroundColor="{AppThemeBinding Light=White, Dark=#1E1E1E}"
                    TextColor="{AppThemeBinding Light=Black, Dark=White}" />

            <Grid ColumnDefinitions="*,*" ColumnSpacing="10">
                <Button Text="Search" />
                <Button Grid.Column="1"
                        Text="Clear" />
            </Grid>

            <ActivityIndicator IsRunning="False"
                               IsVisible="False" />
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
