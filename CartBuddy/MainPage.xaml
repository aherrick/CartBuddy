<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="CartBuddy.MainPage"
             Title="Cart Buddy"
             BackgroundColor="{AppThemeBinding Light=White, Dark=Black}">
    <ScrollView>
        <VerticalStackLayout Padding="16" Spacing="14">
            <Label Text="MainPage bound"
                   FontSize="24"
                   FontAttributes="Bold"
                   TextColor="{AppThemeBinding Light=Black, Dark=White}" />

            <Label Text="{Binding StoreDisplay}"
                   FontSize="14"
                   TextColor="{AppThemeBinding Light=Black, Dark=White}" />

            <Label Text="{Binding ItemsSummary}"
                   FontSize="14"
                   TextColor="{AppThemeBinding Light=Black, Dark=White}" />

            <Editor Text="{Binding RawItemsText}"
                    Placeholder="milk&#10;cheese&#10;water"
                    HeightRequest="140"
                    AutoSize="TextChanges"
                    BackgroundColor="{AppThemeBinding Light=White, Dark=#1E1E1E}"
                    TextColor="{AppThemeBinding Light=Black, Dark=White}" />

            <Grid ColumnDefinitions="*,*" ColumnSpacing="10">
                <Button Text="Search"
                        Command="{Binding SearchCommand}" />
                <Button Grid.Column="1"
                        Text="Clear"
                        Command="{Binding ClearSearchCommand}" />
            </Grid>

            <ActivityIndicator IsRunning="{Binding IsBusy}"
                               IsVisible="{Binding IsBusy}" />
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
