<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="CartBuddy.MainPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:controls="clr-namespace:CartBuddy.Controls"
    xmlns:converters="clr-namespace:CartBuddy.Converters"
    xmlns:local="clr-namespace:CartBuddy"
    xmlns:models="clr-namespace:CartBuddy.Models"
    xmlns:sfListView="clr-namespace:Syncfusion.Maui.ListView;assembly=Syncfusion.Maui.ListView"
    xmlns:toolkit="http://schemas.microsoft.com/dotnet/2022/maui/toolkit"
    xmlns:vm="clr-namespace:CartBuddy.ViewModels"
    x:Name="ThisPage"
    Title="Cart Buddy"
    BackgroundColor="{AppThemeBinding Light={StaticResource Gray100},
                                      Dark={StaticResource Gray950}}">

    <ContentPage.Behaviors>
        <toolkit:StatusBarBehavior StatusBarColor="{AppThemeBinding Light={StaticResource Gray100}, Dark={StaticResource Gray950}}" StatusBarStyle="{AppThemeBinding Light=DarkContent, Dark=LightContent}" />
    </ContentPage.Behaviors>

    <ContentPage.Resources>
        <converters:ExpandIconConverter x:Key="ExpandIconConverter" />
        <converters:ExpandAllGlyphConverter x:Key="ExpandAllGlyphConverter" />
        <converters:GroupInfoConverter x:Key="GroupInfoConverter" />
        <toolkit:InvertedBoolConverter x:Key="InvertedBoolConverter" />
    </ContentPage.Resources>

    <ContentPage.ToolbarItems>
        <ToolbarItem
            Clicked="OnCartClicked"
            Order="Primary"
            Priority="0">
            <ToolbarItem.IconImageSource>
                <FontImageSource
                    FontFamily="FaSolid"
                    Glyph="&#xF07A;"
                    Size="18"
                    Color="{Binding CartIconColor}" />
            </ToolbarItem.IconImageSource>
        </ToolbarItem>
        <ToolbarItem
            Clicked="OnMenuClicked"
            Order="Primary"
            Priority="1">
            <ToolbarItem.IconImageSource>
                <FontImageSource
                    FontFamily="FaSolid"
                    Glyph="&#xF0C9;"
                    Size="18"
                    Color="{AppThemeBinding Light={StaticResource Gray950},
                                            Dark={StaticResource Gray100}}" />
            </ToolbarItem.IconImageSource>
        </ToolbarItem>
    </ContentPage.ToolbarItems>

    <Grid RowDefinitions="Auto,*">
        <BoxView
            x:Name="SnackbarAnchor"
            Grid.Row="1"
            Margin="0,62,0,0"
            HeightRequest="1"
            Opacity="0"
            VerticalOptions="Start" />
        <VerticalStackLayout
            Grid.Row="0"
            Padding="16,14,16,14"
            x:DataType="vm:MainViewModel"
            IsVisible="{Binding HasPreparedSearchTerms}"
            Spacing="14">
            <Grid ColumnDefinitions="*,Auto,Auto,Auto" ColumnSpacing="10">
                <VerticalStackLayout Spacing="2" VerticalOptions="Center">
                    <Label
                        FontAttributes="Bold"
                        FontSize="22"
                        Text="Shopping List" />
                    <Label
                        FontSize="13"
                        LineBreakMode="WordWrap"
                        Text="{Binding SearchTermsSummary}"
                        TextColor="{StaticResource Gray400}" />
                </VerticalStackLayout>
                <Button
                    Grid.Column="1"
                    Padding="12,8"
                    BackgroundColor="{StaticResource Primary}"
                    Clicked="OnEditSearchTermsClicked"
                    CornerRadius="6"
                    FontFamily="FaSolid"
                    FontSize="14"
                    HeightRequest="44"
                    MinimumHeightRequest="44"
                    MinimumWidthRequest="48"
                    SemanticProperties.Description="Edit shopping list"
                    SemanticProperties.Hint="Opens the list editor"
                    Text="&#xF303;"
                    TextColor="{StaticResource White}"
                    VerticalOptions="Center"
                    WidthRequest="48" />
                <Button
                    Grid.Column="2"
                    Padding="12,8"
                    BackgroundColor="{AppThemeBinding Light={StaticResource Secondary},
                                                      Dark={StaticResource Gray900}}"
                    BorderColor="{AppThemeBinding Light={StaticResource Gray300},
                                                  Dark={StaticResource Gray600}}"
                    BorderWidth="1"
                    Clicked="OnToggleExpandAll"
                    CornerRadius="6"
                    FontFamily="FaSolid"
                    FontSize="14"
                    HeightRequest="44"
                    IsVisible="{Binding HasResults}"
                    MinimumHeightRequest="44"
                    MinimumWidthRequest="48"
                    SemanticProperties.Description="Toggle group expansion"
                    SemanticProperties.Hint="Expands or collapses all shopping list groups"
                    Text="{Binding AllGroupsExpanded, Converter={StaticResource ExpandAllGlyphConverter}}"
                    TextColor="{AppThemeBinding Light={StaticResource Tertiary},
                                                Dark={StaticResource Gray200}}"
                    VerticalOptions="Center"
                    WidthRequest="48" />
                <Button
                    Grid.Column="3"
                    Padding="12,8"
                    BackgroundColor="{StaticResource SaleRed}"
                    Clicked="OnClearSearchClicked"
                    CornerRadius="6"
                    FontFamily="FaSolid"
                    FontSize="14"
                    HeightRequest="44"
                    IsVisible="{Binding HasPreparedSearchTerms}"
                    MinimumHeightRequest="44"
                    MinimumWidthRequest="48"
                    SemanticProperties.Description="Clear shopping list"
                    SemanticProperties.Hint="Removes the current confirmed list and search results"
                    Text="&#xF1F8;"
                    TextColor="{StaticResource White}"
                    VerticalOptions="Center"
                    WidthRequest="48" />
            </Grid>
        </VerticalStackLayout>

        <Grid Grid.Row="1">
            <Grid RowDefinitions="Auto,*">
                <BoxView
                    Grid.Row="0"
                    BackgroundColor="{AppThemeBinding Light={StaticResource Gray200},
                                                      Dark={StaticResource Gray600}}"
                    HeightRequest="1"
                    IsVisible="{Binding HasResults}" />
                <VerticalStackLayout
                    Grid.Row="1"
                    Margin="24,0"
                    HorizontalOptions="Center"
                    IsVisible="{Binding ShowEmptyState}"
                    MaximumWidthRequest="360"
                    Spacing="10"
                    VerticalOptions="Center">
                    <Label
                        FontFamily="FaSolid"
                        FontSize="40"
                        HorizontalTextAlignment="Center"
                        Text="&#xF03A;"
                        TextColor="{StaticResource Gray500}" />
                    <Label
                        FontAttributes="Bold"
                        FontSize="18"
                        HorizontalTextAlignment="Center"
                        Text="{Binding EmptyStateTitle}" />
                    <Label
                        FontSize="13"
                        HorizontalTextAlignment="Center"
                        Text="{Binding EmptyStateDescription}"
                        TextColor="{StaticResource Gray400}" />
                    <Button
                        Clicked="OnEditSearchTermsClicked"
                        HorizontalOptions="Fill"
                        Text="{Binding SearchTermsActionText}" />
                </VerticalStackLayout>

                <sfListView:SfListView
                    x:Name="SearchListView"
                    Grid.Row="1"
                    Margin="0,0,0,0"
                    AllowGroupExpandCollapse="True"
                    AutoFitMode="Height"
                    GroupExpanded="OnGroupExpanded"
                    GroupCollapsed="OnGroupCollapsed"
                    GroupHeaderSize="58"
                    IsStickyGroupHeader="True"
                    IsVisible="{Binding HasResults}"
                    ItemsSource="{Binding AllProducts}"
                    SelectionMode="None">
                    <sfListView:SfListView.GroupHeaderTemplate>
                        <DataTemplate x:DataType="{x:Null}">
                            <Grid
                                Padding="16,10,16,10"
                                BackgroundColor="{AppThemeBinding Light={StaticResource Gray100},
                                                                  Dark={StaticResource Gray950}}"
                                ColumnDefinitions="Auto,*,Auto,Auto"
                                ColumnSpacing="8">
                                <Label
                                    Grid.Column="0"
                                    FontFamily="FaSolid"
                                    FontSize="13"
                                    Text="{Binding IsExpand, Converter={StaticResource ExpandIconConverter}}"
                                    TextColor="{AppThemeBinding Light={StaticResource Gray500},
                                                                Dark={StaticResource Gray400}}"
                                    VerticalOptions="Center" />
                                <VerticalStackLayout
                                    Grid.Column="1"
                                    Spacing="4"
                                    VerticalOptions="Center">
                                    <HorizontalStackLayout Spacing="6" VerticalOptions="Center">
                                        <Label
                                            FontAttributes="Bold"
                                            FontSize="17"
                                            Text="{Binding Key}" />
                                        <Label
                                            FontFamily="FaSolid"
                                            FontSize="14"
                                            Text="&#xF058;"
                                            TextColor="{StaticResource SaleGreen}"
                                            VerticalOptions="Center">
                                            <Label.IsVisible>
                                                <MultiBinding Converter="{StaticResource GroupInfoConverter}" ConverterParameter="IsCompleted">
                                                    <Binding Path="Key" />
                                                    <Binding Path="BindingContext.SearchGroups" Source="{x:Reference ThisPage}" />
                                                    <Binding Path="BindingContext.GroupStateVersion" Source="{x:Reference ThisPage}" />
                                                </MultiBinding>
                                            </Label.IsVisible>
                                        </Label>
                                    </HorizontalStackLayout>
                                    <Border
                                        Padding="8,3"
                                        BackgroundColor="{AppThemeBinding Light={StaticResource Secondary},
                                                                          Dark={StaticResource Gray600}}"
                                        HorizontalOptions="Start"
                                        StrokeShape="RoundRectangle 999"
                                        StrokeThickness="0">
                                        <Label
                                            FontAttributes="Bold"
                                            FontSize="11"
                                            TextColor="{AppThemeBinding Light={StaticResource Primary},
                                                                        Dark={StaticResource White}}">
                                            <Label.Text>
                                                <MultiBinding Converter="{StaticResource GroupInfoConverter}" ConverterParameter="CategoryLabel">
                                                    <Binding Path="Key" />
                                                    <Binding Path="BindingContext.SearchGroups" Source="{x:Reference ThisPage}" />
                                                    <Binding Path="BindingContext.GroupStateVersion" Source="{x:Reference ThisPage}" />
                                                </MultiBinding>
                                            </Label.Text>
                                        </Label>
                                    </Border>
                                </VerticalStackLayout>
                                <Label
                                    Grid.Column="2"
                                    FontSize="13"
                                    TextColor="{StaticResource Gray400}"
                                    VerticalOptions="Center">
                                    <Label.Text>
                                        <MultiBinding Converter="{StaticResource GroupInfoConverter}" ConverterParameter="PageSummary">
                                            <Binding Path="Key" />
                                            <Binding Path="BindingContext.SearchGroups" Source="{x:Reference ThisPage}" />
                                            <Binding Path="BindingContext.GroupStateVersion" Source="{x:Reference ThisPage}" />
                                        </MultiBinding>
                                    </Label.Text>
                                </Label>
                                <Button
                                    Grid.Column="3"
                                    Padding="10,4"
                                    BackgroundColor="Transparent"
                                    BorderColor="{AppThemeBinding Light={StaticResource Gray300},
                                                                  Dark={StaticResource Gray600}}"
                                    BorderWidth="1"
                                    Command="{Binding Source={x:Reference ThisPage}, Path=ViewMoreCommand}"
                                    CornerRadius="16"
                                    FontSize="12"
                                    MinimumHeightRequest="32"
                                    MinimumWidthRequest="88"
                                    Text="View More"
                                    TextColor="{AppThemeBinding Light={StaticResource Tertiary},
                                                                Dark={StaticResource Gray200}}">
                                    <Button.CommandParameter>
                                        <MultiBinding Converter="{StaticResource GroupInfoConverter}" ConverterParameter="Group">
                                            <Binding Path="Key" />
                                            <Binding Path="BindingContext.SearchGroups" Source="{x:Reference ThisPage}" />
                                            <Binding Path="BindingContext.GroupStateVersion" Source="{x:Reference ThisPage}" />
                                        </MultiBinding>
                                    </Button.CommandParameter>
                                    <Button.IsVisible>
                                        <MultiBinding Converter="{StaticResource GroupInfoConverter}" ConverterParameter="HasMore">
                                            <Binding Path="Key" />
                                            <Binding Path="BindingContext.SearchGroups" Source="{x:Reference ThisPage}" />
                                            <Binding Path="BindingContext.GroupStateVersion" Source="{x:Reference ThisPage}" />
                                        </MultiBinding>
                                    </Button.IsVisible>
                                </Button>
                            </Grid>
                        </DataTemplate>
                    </sfListView:SfListView.GroupHeaderTemplate>
                    <sfListView:SfListView.ItemTemplate>
                        <DataTemplate x:DataType="models:ProductMatch">
                            <Grid>
                                <controls:ProductListItemView
                                    Title="{Binding Description}"
                                    Margin="16,0"
                                    AccentColor="{StaticResource SaleRed}"
                                    AccentText="{Binding PromoEndDisplay}"
                                    Detail="{Binding Size}"
                                    ImageUrl="{Binding ImageUrl}"
                                    IsVisible="{Binding IsNoResult, Converter={StaticResource InvertedBoolConverter}}"
                                    ItemCommand="{Binding Source={x:Reference ThisPage}, Path=AddToCartCommand, x:DataType=local:MainPage}"
                                    ItemCommandParameter="{Binding}"
                                    PriceBadgeColor="{StaticResource SaleGreen}"
                                    PriceColor="{AppThemeBinding Light={StaticResource Gray950},
                                                                 Dark={StaticResource Gray100}}"
                                    PriceText="{Binding PriceDisplay}"
                                    SecondaryPriceStrikethrough="{Binding RegularPriceDisplayIsStrikethrough}"
                                    SecondaryPriceText="{Binding RegularPriceDisplay}"
                                    ShowPriceBadge="{Binding HasSale}"
                                    Subtitle="{Binding DisplayBrand}" />
                                <Label
                                    Margin="16,12"
                                    FontSize="14"
                                    IsVisible="{Binding IsNoResult}"
                                    Text="{Binding NoResultMessage}"
                                    TextColor="{StaticResource Gray400}" />
                            </Grid>
                        </DataTemplate>
                    </sfListView:SfListView.ItemTemplate>
                </sfListView:SfListView>
            </Grid>
        </Grid>
    </Grid>
</ContentPage>
