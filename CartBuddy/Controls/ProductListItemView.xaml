<?xml version="1.0" encoding="utf-8" ?>
<ContentView xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="CartBuddy.Controls.ProductListItemView"
             x:Name="ThisView">
    <ContentView.GestureRecognizers>
        <TapGestureRecognizer Command="{Binding ItemCommand, Source={x:Reference ThisView}}"
                              CommandParameter="{Binding ItemCommandParameter, Source={x:Reference ThisView}}" />
    </ContentView.GestureRecognizers>

    <Grid RowDefinitions="Auto,Auto" RowSpacing="0">
        <Grid ColumnDefinitions="60,*,Auto" ColumnSpacing="12" Padding="0,10">
            <Border WidthRequest="60"
                    HeightRequest="60"
                    Padding="2"
                    Stroke="{AppThemeBinding Light={StaticResource Gray200}, Dark={StaticResource Gray600}}"
                    StrokeThickness="1"
                    StrokeShape="RoundRectangle 8"
                    BackgroundColor="{AppThemeBinding Light={StaticResource White}, Dark={StaticResource OffBlack}}">
                <Image Source="{Binding ImageUrl, Source={x:Reference ThisView}}" Aspect="AspectFit" />
            </Border>

            <VerticalStackLayout Grid.Column="1" Spacing="2" VerticalOptions="Center">
                <Label Text="{Binding Title, Source={x:Reference ThisView}}"
                       FontSize="14"
                       FontAttributes="Bold"
                       LineBreakMode="TailTruncation"
                       MaxLines="2" />
                <Label Text="{Binding Subtitle, Source={x:Reference ThisView}}"
                       FontSize="12"
                       TextColor="{StaticResource Gray400}"
                       IsVisible="{Binding HasSubtitle, Source={x:Reference ThisView}}" />
                <Label Text="{Binding Detail, Source={x:Reference ThisView}}"
                       FontSize="12"
                       TextColor="{StaticResource Gray400}"
                       IsVisible="{Binding HasDetail, Source={x:Reference ThisView}}" />
            </VerticalStackLayout>

            <VerticalStackLayout Grid.Column="2" Spacing="2" HorizontalOptions="End" VerticalOptions="Center">
                <Border Padding="10,4"
                        StrokeThickness="0"
                        StrokeShape="RoundRectangle 6"
                        HorizontalOptions="End"
                        BackgroundColor="{Binding PriceBadgeColor, Source={x:Reference ThisView}}"
                        IsVisible="{Binding ShowPriceBadge, Source={x:Reference ThisView}}">
                    <Label Text="{Binding PriceText, Source={x:Reference ThisView}}"
                           FontSize="18"
                           FontAttributes="Bold"
                           HorizontalTextAlignment="End"
                           TextColor="{StaticResource White}" />
                </Border>
                <Label Text="{Binding PriceText, Source={x:Reference ThisView}}"
                       FontSize="18"
                       FontAttributes="Bold"
                       HorizontalTextAlignment="End"
                       TextColor="{Binding PriceColor, Source={x:Reference ThisView}}"
                       IsVisible="{Binding ShowPlainPrice, Source={x:Reference ThisView}}" />
                <Label Text="{Binding SecondaryPriceText, Source={x:Reference ThisView}}"
                       FontSize="11"
                       HorizontalTextAlignment="End"
                       TextColor="{StaticResource Gray400}"
                       TextDecorations="Strikethrough"
                       IsVisible="{Binding HasSecondaryPriceText, Source={x:Reference ThisView}}" />
                <Label Text="{Binding AccentText, Source={x:Reference ThisView}}"
                       FontSize="11"
                       HorizontalTextAlignment="End"
                       TextColor="{Binding AccentColor, Source={x:Reference ThisView}}"
                       IsVisible="{Binding HasAccentText, Source={x:Reference ThisView}}" />

                <HorizontalStackLayout Spacing="4"
                                       HorizontalOptions="End"
                                       IsVisible="{Binding ShowQuantityControls, Source={x:Reference ThisView}}">
                    <Button Text="-"
                            Command="{Binding DecreaseCommand, Source={x:Reference ThisView}}"
                            CommandParameter="{Binding QuantityCommandParameter, Source={x:Reference ThisView}}"
                            Padding="10,6"
                            FontSize="12"
                            WidthRequest="38"
                            TextColor="{StaticResource SaleRed}"
                            BackgroundColor="Transparent"
                            BorderColor="{StaticResource SaleRed}"
                            BorderWidth="1" />
                    <Border Padding="10,6"
                            StrokeThickness="0"
                            StrokeShape="RoundRectangle 6"
                            BackgroundColor="{AppThemeBinding Light={StaticResource Gray200}, Dark={StaticResource Gray900}}">
                        <Label Text="{Binding QuantityText, Source={x:Reference ThisView}}"
                               WidthRequest="18"
                               HorizontalTextAlignment="Center"
                               VerticalTextAlignment="Center" />
                    </Border>
                    <Button Text="+"
                            Command="{Binding IncreaseCommand, Source={x:Reference ThisView}}"
                            CommandParameter="{Binding QuantityCommandParameter, Source={x:Reference ThisView}}"
                            Padding="10,6"
                            FontSize="12"
                            WidthRequest="38"
                            TextColor="{StaticResource SaleGreen}"
                            BackgroundColor="Transparent"
                            BorderColor="{StaticResource SaleGreen}"
                            BorderWidth="1" />
                </HorizontalStackLayout>
            </VerticalStackLayout>
        </Grid>

        <BoxView Grid.Row="1"
                 HeightRequest="1"
                 BackgroundColor="{AppThemeBinding Light={StaticResource Gray200}, Dark={StaticResource Gray600}}" />
    </Grid>
</ContentView>
