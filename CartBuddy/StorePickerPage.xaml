<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:CartBuddy.ViewModels"
             xmlns:models="clr-namespace:CartBuddy.Models"
             x:Class="CartBuddy.StorePickerPage"
             x:Name="ThisPage"
             Title="Select Store">

    <Grid RowDefinitions="Auto,*,Auto" Padding="16" RowSpacing="12">

        <!-- Row 0: Zip Code Input -->
        <HorizontalStackLayout Spacing="8">
            <Entry Text="{Binding ZipCode}"
                   Placeholder="Enter zip code"
                   Keyboard="Numeric"
                   WidthRequest="160"
                   ReturnCommand="{Binding SearchStoresCommand}" />
            <Button Text="🔍 Search" Command="{Binding SearchStoresCommand}" />
        </HorizontalStackLayout>

        <!-- Row 1: Store List -->
        <CollectionView Grid.Row="1" ItemsSource="{Binding Stores}">
            <CollectionView.EmptyView>
                <Label Text="Enter a zip code to find nearby Kroger stores"
                       HorizontalOptions="Center"
                       VerticalOptions="Center"
                       TextColor="{StaticResource Gray400}" />
            </CollectionView.EmptyView>
            <CollectionView.ItemTemplate>
                <DataTemplate x:DataType="models:KrogerLocation">
                    <Border Margin="0,4" Padding="12" StrokeShape="RoundRectangle 8">
                        <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8">
                            <VerticalStackLayout VerticalOptions="Center">
                                <Label Text="{Binding Name}" FontSize="16" FontAttributes="Bold" />
                                <Label Text="{Binding Address.AddressLine1}" FontSize="13" />
                                <Label Text="{Binding Address.City}" FontSize="12"
                                       TextColor="{StaticResource Gray400}" />
                            </VerticalStackLayout>
                            <Button Grid.Column="1" Text="Select" VerticalOptions="Center"
                                    Command="{Binding Path=BindingContext.SelectStoreCommand, Source={x:Reference ThisPage}}"
                                    CommandParameter="{Binding}" />
                        </Grid>
                    </Border>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>

        <!-- Row 2: Status -->
        <VerticalStackLayout Grid.Row="2" Spacing="4">
            <ActivityIndicator IsRunning="{Binding IsBusy}" IsVisible="{Binding IsBusy}"
                               HeightRequest="20" />
            <Label Text="{Binding StatusMessage}" HorizontalOptions="Center" FontSize="12" />
        </VerticalStackLayout>
    </Grid>
</ContentPage>