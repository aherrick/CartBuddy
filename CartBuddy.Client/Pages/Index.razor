@page "/"
@using CartBuddy.Shared.Models

<div class="container mt-4" style="max-width:900px;">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h3 class="mb-0 fw-bold text-primary">
            <iconify-icon icon="mdi:cart" class="me-2 align-middle"></iconify-icon>CartBuddy
        </h3>
        @if (selectedStore != null)
        {
            <div class="d-flex align-items-center gap-2">
                <div class="text-end">
                    <div class="fw-bold"><iconify-icon icon="mdi:store" class="me-1"></iconify-icon>@selectedStore.Name</div>
                    <div class="text-muted small">@selectedStore.Address</div>
                </div>
                <button @onclick="ChangeStore" class="btn btn-sm btn-outline-secondary">
                    <iconify-icon icon="mdi:swap-horizontal"></iconify-icon>
                </button>
            </div>
        }
    </div>

    <div class="row">
        <div class="col-md-7">
            @if (showLocationSearch)
            {
                <div class="card mb-3 shadow-sm border-0 rounded-3">
                    <div class="card-body">
                        <label class="form-label fw-semibold"><iconify-icon icon="mdi:map-marker" class="me-1 align-text-bottom"></iconify-icon>ZIP Code</label>
                        <div class="input-group mb-2">
                            <input @bind="zipCode" @bind:after="PersistZipCodeAsync" class="form-control" disabled="@isLoadingLocations" />
                            <button @onclick="SetLocation" class="btn btn-primary" disabled="@isLoadingLocations">
                                <iconify-icon icon="mdi:magnify" class="me-1"></iconify-icon>@(isLoadingLocations ? "Finding..." : "Find Stores")
                            </button>
                        </div>

                        @if (locations.Any())
                        {
                            <div class="list-group">
                                @foreach (var loc in locations)
                                {
                                    <button @onclick="() => SelectLocation(loc.LocationId)" class="list-group-item list-group-item-action @(locationId == loc.LocationId ? "active" : "")">
                                        <div class="fw-bold"><iconify-icon icon="mdi:store-marker" class="me-1"></iconify-icon>@loc.Name</div>
                                        <small>@loc.Address</small>
                                    </button>
                                }
                            </div>
                        }
                    </div>
                </div>
            }

            <div class="card mb-4 shadow-sm border-0 rounded-3">
                <div class="card-body p-4">
                    <label class="form-label fw-bold"><iconify-icon icon="mdi:format-list-bulleted" class="me-1 align-text-bottom"></iconify-icon>Shopping List</label>
                    <textarea @bind="itemsText" @bind:after="PersistItemsTextAsync" rows="4" class="form-control mb-3" placeholder="Enter items one per line..." disabled="@(string.IsNullOrEmpty(locationId) || isSearching)"></textarea>
                    <button @onclick="SearchItems" class="btn btn-primary w-100 fw-bold" disabled="@(string.IsNullOrEmpty(locationId) || isSearching)">
                        <iconify-icon icon="mdi:magnify" class="me-2 align-middle"></iconify-icon>@(isSearching ? "Searching..." : "Search Items")
                    </button>
                </div>
            </div>

            @if (searchResults.Any())
            {
                <div class="d-flex justify-content-between align-items-center mb-3">
                    <h5 class="mb-0">Matched Items</h5>
                    <button @onclick="ToggleAllCollapse" class="btn btn-sm btn-outline-secondary">
                        <iconify-icon icon="@(allCollapsed ? "mdi:unfold-more-horizontal" : "mdi:unfold-less-horizontal")" class="me-1"></iconify-icon>
                        @(allCollapsed ? "Expand All" : "Collapse All")
                    </button>
                </div>
            }

            @foreach (var termResult in searchResults)
            {
                var collapseId = $"collapse-{searchResults.IndexOf(termResult)}";
                var hasMore = termResult.NextStart < termResult.TotalAvailable;
                var isFulfilled = IsTermFulfilled(termResult);
                var currentPage = termResult.NextStart / SearchConstants.PageSize;
                var totalPages = (int)Math.Ceiling(termResult.TotalAvailable / (double)SearchConstants.PageSize);
                <div class="card mb-3">
                    <div class="card-header d-flex justify-content-between align-items-center">
                        <button @onclick="() => ToggleCollapse(termResult)" class="btn btn-link text-decoration-none p-0 text-start flex-grow-1">
                            <iconify-icon icon="@(termResult.IsCollapsed ? "mdi:chevron-right" : "mdi:chevron-down")" class="me-1"></iconify-icon>
                            <strong>@termResult.Term</strong>
                            @if (isFulfilled)
                            {
                                <iconify-icon icon="mdi:check-circle" class="ms-2 text-success"></iconify-icon>
                            }
                        </button>
                        @if (!termResult.IsCollapsed && termResult.TotalAvailable > SearchConstants.PageSize)
                        {
                            <div class="d-flex align-items-center gap-2">
                                <span class="badge bg-secondary">@currentPage/@totalPages</span>
                                <button @onclick="() => LoadMore(termResult)" class="btn btn-sm btn-outline-primary" disabled="@(!hasMore)">
                                    <iconify-icon icon="mdi:chevron-down" class="me-1"></iconify-icon>View More
                                </button>
                            </div>
                        }
                    </div>
                    @if (!termResult.IsCollapsed)
                    {
                        <div class="list-group list-group-flush">
                            @foreach (var product in termResult.Results)
                            {
                                <div class="list-group-item list-group-item-action" style="cursor: pointer;" @onclick="() => AddToCart(product, termResult)">
                                    <div class="d-flex align-items-center">
                                        @if (!string.IsNullOrEmpty(product.ImageUrl))
                                        {
                                            <img src="@product.ImageUrl" alt="@product.Description" class="me-3" style="width:80px;height:80px;object-fit:contain;flex-shrink:0;" />
                                        }
                                        <div class="flex-grow-1">
                                            <div class="fw-bold">@product.Brand</div>
                                            <div>@product.Description</div>
                                            <div class="text-muted small">@product.Size</div>
                                        </div>
                                        <div class="text-end ms-3" style="flex-shrink:0;">
                                            @if (product.HasPromo)
                                            {
                                                <div>
                                                    <span class="badge bg-success" style="font-size:1rem;padding:0.4rem 0.8rem;">$@product.Price.ToString("F2")</span>
                                                    <div class="text-muted text-decoration-line-through small mt-1">(Reg $@product.RegularPrice.Value.ToString("F2"))</div>
                                                </div>
                                                @if (!string.IsNullOrEmpty(product.PromoEndDate))
                                                {
                                                    var endDate = DateTime.Parse(product.PromoEndDate);
                                                    <div class="text-danger small mt-1">Until @endDate.ToString("M/d")</div>
                                                }
                                            }
                                            else
                                            {
                                                <div class="text-success fw-bold" style="font-size:1.1rem;">@(product.SoldByWeight ? "by wt." : $"${product.Price:F2}")</div>
                                            }
                                        </div>
                                    </div>
                                </div>
                            }
                        </div>
                    }
                </div>
            }

        </div>

        <div class="col-md-5">
            <div class="card shadow-sm border-0 rounded-3 sticky-top mb-4" style="top:20px;">
                <div class="card-header bg-primary text-white d-flex justify-content-between align-items-center rounded-top-3 border-0 py-3">
                    <span class="fw-bold"><iconify-icon icon="mdi:cart" class="me-2 align-middle"></iconify-icon>Your Cart</span>
                    <span class="badge bg-white text-primary rounded-pill fw-bold" style="font-size: 0.9rem;">
                        @TotalQuantity items &bull; $@TotalPrice.ToString("F2")
                    </span>
                </div>
                <div class="card-body p-4 bg-light">
                    <button @onclick="Checkout" disabled="@(cart.Count == 0 || isCheckingOut)" class="btn btn-success w-100 mb-2 py-2 fw-bold shadow-sm">
                        <iconify-icon icon="mdi:credit-card-check" class="me-2 align-middle"></iconify-icon>@(isCheckingOut ? "Starting checkout..." : "Checkout Now")
                    </button>

                    @if (cart.Count > 0)
                    {
                        <button @onclick="PromptClearCart" class="btn btn-outline-danger w-100 mb-4 py-2 fw-semibold" disabled="@isCheckingOut">
                            <iconify-icon icon="mdi:cart-remove" class="me-2 align-middle"></iconify-icon>Clear Cart
                        </button>
                    }

                    @if (cart.Count == 0)
                    {
                        <div class="text-center text-muted my-4 py-3">
                            <iconify-icon icon="mdi:cart-outline" style="font-size: 3rem; opacity: 0.5;" class="mb-2 d-block mx-auto"></iconify-icon>
                            <p class="mb-0">Your cart is empty</p>
                        </div>
                    }

                    @foreach (var item in cart)
                    {
                        <div class="card mb-3 border-0 shadow-sm rounded-3 overflow-hidden">
                            <div class="row g-0">
                                @if (!string.IsNullOrEmpty(item.ImageUrl))
                                {
                                    <div class="col-3 p-2 d-flex align-items-center bg-white">
                                        <img src="@item.ImageUrl" alt="@item.Description" class="img-fluid rounded" style="object-fit:contain; max-height: 60px; width: 100%;" />
                                    </div>
                                }
                                <div class="@(string.IsNullOrEmpty(item.ImageUrl) ? "col-12" : "col-9") d-flex flex-column">
                                    <div class="card-body p-3 flex-grow-1">
                                        <div class="fw-semibold text-truncate small mb-1" title="@item.Description">@item.Description</div>
                                        <div class="d-flex justify-content-between align-items-center mt-2">
                                            <div class="text-success fw-bold">$@item.Price.ToString("F2")</div>
                                            <div class="d-flex align-items-center bg-light rounded-pill border p-1" style="transform: scale(0.9);">
                                                <button @onclick="() => DecreaseQuantity(item)" class="btn btn-sm btn-link text-danger text-decoration-none p-0 px-2 m-0 d-flex align-items-center">
                                                    <iconify-icon icon="mdi:minus" style="font-size:1.1rem;"></iconify-icon>
                                                </button>
                                                <span class="fw-bold px-2 text-dark" style="min-width: 20px; text-align: center;">@item.Quantity</span>
                                                <button @onclick="() => IncreaseQuantity(item)" class="btn btn-sm btn-link text-success text-decoration-none p-0 px-2 m-0 d-flex align-items-center">
                                                    <iconify-icon icon="mdi:plus" style="font-size:1.1rem;"></iconify-icon>
                                                </button>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>
</div>


