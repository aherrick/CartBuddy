@page "/"
@using CartBuddy.Shared.Models

<div class="container mt-4" style="max-width:900px;">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h3 class="mb-0">
            <iconify-icon icon="mdi:cart" class="me-2"></iconify-icon>CartBuddy
        </h3>
        @if (selectedStore != null)
        {
            <div class="d-flex align-items-center gap-2">
                <div class="text-end">
                    <div class="fw-bold"><iconify-icon icon="mdi:store" class="me-1"></iconify-icon>@selectedStore.Name</div>
                    <div class="text-muted small">@selectedStore.Address</div>
                </div>
                <button @onclick="ChangeStore" class="btn btn-sm btn-outline-secondary">
                    <iconify-icon icon="mdi:swap-horizontal"></iconify-icon>
                </button>
            </div>
        }
    </div>

    <div class="row">
        <div class="col-md-7">
            @if (showLocationSearch)
            {
                <div class="card mb-3">
                    <div class="card-body">
                        <label class="form-label"><iconify-icon icon="mdi:map-marker" class="me-1"></iconify-icon>ZIP Code</label>
                        <div class="input-group mb-2">
                            <input @bind="zipCode" @bind:after="PersistZipCodeAsync" class="form-control" disabled="@isLoadingLocations" />
                            <button @onclick="SetLocation" class="btn btn-primary" disabled="@isLoadingLocations">
                                <iconify-icon icon="mdi:magnify" class="me-1"></iconify-icon>@(isLoadingLocations ? "Finding..." : "Find Stores")
                            </button>
                        </div>

                        @if (locations.Any())
                        {
                            <div class="list-group">
                                @foreach (var loc in locations)
                                {
                                    <button @onclick="() => SelectLocation(loc.LocationId)" class="list-group-item list-group-item-action @(locationId == loc.LocationId ? "active" : "")">
                                        <div class="fw-bold"><iconify-icon icon="mdi:store-marker" class="me-1"></iconify-icon>@loc.Name</div>
                                        <small>@loc.Address</small>
                                    </button>
                                }
                            </div>
                        }
                    </div>
                </div>
            }

            <div class="card mb-3">
                <div class="card-body">
                    <label class="form-label"><iconify-icon icon="mdi:format-list-bulleted" class="me-1"></iconify-icon>Items (one per line)</label>
                    <textarea @bind="itemsText" @bind:after="PersistItemsTextAsync" rows="4" class="form-control mb-2" disabled="@(string.IsNullOrEmpty(locationId) || isSearching)"></textarea>
                    <button @onclick="SearchItems" class="btn btn-success" disabled="@(string.IsNullOrEmpty(locationId) || isSearching)">
                        <iconify-icon icon="mdi:magnify" class="me-1"></iconify-icon>@(isSearching ? "Searching..." : "Search")
                    </button>
                </div>
            </div>

            @if (searchResults.Any())
            {
                <div class="d-flex justify-content-between align-items-center mb-3">
                    <h5 class="mb-0">Matched Items</h5>
                    <button @onclick="ToggleAllCollapse" class="btn btn-sm btn-outline-secondary">
                        <iconify-icon icon="@(allCollapsed ? "mdi:unfold-more-horizontal" : "mdi:unfold-less-horizontal")" class="me-1"></iconify-icon>
                        @(allCollapsed ? "Expand All" : "Collapse All")
                    </button>
                </div>
            }

            @foreach (var termResult in searchResults)
            {
                var collapseId = $"collapse-{searchResults.IndexOf(termResult)}";
                var hasMore = termResult.NextStart < termResult.TotalAvailable;
                var isFulfilled = IsTermFulfilled(termResult);
                var currentPage = termResult.NextStart / SearchPageSize;
                var totalPages = (int)Math.Ceiling(termResult.TotalAvailable / (double)SearchPageSize);
                <div class="card mb-3">
                    <div class="card-header d-flex justify-content-between align-items-center">
                        <button @onclick="() => ToggleCollapse(termResult)" class="btn btn-link text-decoration-none p-0 text-start flex-grow-1">
                            <iconify-icon icon="@(termResult.IsCollapsed ? "mdi:chevron-right" : "mdi:chevron-down")" class="me-1"></iconify-icon>
                            <strong>@termResult.Term</strong>
                            @if (isFulfilled)
                            {
                                <iconify-icon icon="mdi:check-circle" class="ms-2 text-success"></iconify-icon>
                            }
                        </button>
                        @if (!termResult.IsCollapsed && termResult.TotalAvailable > SearchPageSize)
                        {
                            <div class="d-flex align-items-center gap-2">
                                <span class="badge bg-secondary">@currentPage/@totalPages</span>
                                <button @onclick="() => LoadMore(termResult)" class="btn btn-sm btn-outline-primary" disabled="@(!hasMore)">
                                    <iconify-icon icon="mdi:chevron-down" class="me-1"></iconify-icon>View More
                                </button>
                            </div>
                        }
                    </div>
                    @if (!termResult.IsCollapsed)
                    {
                        <div class="list-group list-group-flush">
                            @foreach (var product in termResult.Results)
                            {
                                <div class="list-group-item list-group-item-action" style="cursor: pointer;" @onclick="() => AddToCart(product, termResult)">
                                    <div class="d-flex align-items-center">
                                        @if (!string.IsNullOrEmpty(product.ImageUrl))
                                        {
                                            <img src="@product.ImageUrl" alt="@product.Description" class="me-3" style="width:80px;height:80px;object-fit:contain;flex-shrink:0;" />
                                        }
                                        <div class="flex-grow-1">
                                            <div class="fw-bold">@product.Brand</div>
                                            <div>@product.Description</div>
                                            <div class="text-muted small">@product.Size</div>
                                        </div>
                                        <div class="text-end ms-3" style="flex-shrink:0;">
                                            @if (product.HasPromo)
                                            {
                                                <div>
                                                    <span class="badge bg-success" style="font-size:1rem;padding:0.4rem 0.8rem;">$@product.Price.ToString("F2")</span>
                                                    <div class="text-muted text-decoration-line-through small mt-1">(Reg $@product.RegularPrice.Value.ToString("F2"))</div>
                                                </div>
                                                @if (!string.IsNullOrEmpty(product.PromoEndDate))
                                                {
                                                    var endDate = DateTime.Parse(product.PromoEndDate);
                                                    <div class="text-danger small mt-1">Until @endDate.ToString("M/d")</div>
                                                }
                                            }
                                            else
                                            {
                                                <div class="text-success fw-bold" style="font-size:1.1rem;">$@product.Price.ToString("F2")</div>
                                            }
                                        </div>
                                    </div>
                                </div>
                            }
                        </div>
                    }
                </div>
            }

        </div>

        <div class="col-md-5">
            <div class="card sticky-top" style="top:20px;">
                <div class="card-header d-flex justify-content-between align-items-center">
                    <span><iconify-icon icon="mdi:cart" class="me-1"></iconify-icon>Cart</span>
                    <span class="badge bg-primary rounded-pill">@TotalQuantity items - $@TotalPrice.ToString("F2")</span>
                </div>
                <div class="card-body">
                    <button @onclick="Checkout" disabled="@(cart.Count == 0 || isCheckingOut)" class="btn btn-success w-100 mb-3">
                        <iconify-icon icon="mdi:credit-card-check" class="me-1"></iconify-icon>@(isCheckingOut ? "Starting checkout..." : "Checkout")
                    </button>

                    @if (cart.Count > 0)
                    {
                        <button @onclick="PromptClearCart" class="btn btn-outline-secondary w-100 mb-3" disabled="@isCheckingOut">
                            <iconify-icon icon="mdi:cart-remove" class="me-1"></iconify-icon>Clear Cart
                        </button>
                    }

                    @if (cart.Count == 0)
                    {
                        <p class="text-muted text-center">Your cart is empty</p>
                    }

                    @foreach (var item in cart)
                    {
                        <div class="card mb-2 border">
                            <div class="card-body p-3">
                                <div class="d-flex align-items-center mb-2">
                                    @if (!string.IsNullOrEmpty(item.ImageUrl))
                                    {
                                        <img src="@item.ImageUrl" alt="@item.Description" class="me-2" style="width:50px;height:50px;object-fit:contain;" />
                                    }
                                    <div class="flex-grow-1 small">
                                        <div>@item.Description</div>
                                        <div class="text-success fw-bold">$@item.Price.ToString("F2")</div>
                                    </div>
                                </div>
                                <div class="d-flex align-items-center justify-content-center gap-2">
                                    <button @onclick="() => DecreaseQuantity(item)" class="btn btn-outline-danger">
                                        <iconify-icon icon="mdi:minus" style="font-size:1.2rem;"></iconify-icon>
                                    </button>
                                    <span class="badge bg-secondary" style="font-size:1rem;min-width:50px;padding:0.5rem;">@item.Quantity</span>
                                    <button @onclick="() => IncreaseQuantity(item)" class="btn btn-outline-success">
                                        <iconify-icon icon="mdi:plus" style="font-size:1.2rem;"></iconify-icon>
                                    </button>
                                </div>
                            </div>
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>
</div>


